@inject IJSRuntime Js

@if (IsOpen)
{
    <div class="modal-backdrop" @onclick="CancelAsync">
        <section @ref="_dialog"
                 class="confirm-dialog card"
                 data-testid="confirm-dialog"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="@_titleId"
                 aria-describedby="@_messageId"
                 tabindex="-1"
                 @onclick:stopPropagation="true"
                 @onkeydown="HandleKeyDownAsync">
            <p class="eyebrow">@Eyebrow</p>
            <h2 id="@_titleId">@Title</h2>
            <p id="@_messageId" data-testid="confirm-message">@Message</p>
            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <p class="operation-error" role="alert">@ErrorMessage</p>
            }
            <div class="confirm-dialog__actions">
                <button id="@ConfirmButtonId"
                        type="button"
                        class="button button-danger"
                        data-testid="confirm-accept"
                        @onclick="ConfirmAsync"
                        disabled="@IsBusy">
                    @(IsBusy ? BusyText : ConfirmText)
                </button>
                <button id="@CancelButtonId"
                        type="button"
                        class="button button-secondary"
                        data-testid="confirm-cancel"
                        data-autofocus="true"
                        @onclick="CancelAsync"
                        disabled="@IsBusy">
                    @CancelText
                </button>
            </div>
        </section>
    </div>
}

@code {
    private readonly string _titleId = $"confirm-title-{Guid.NewGuid():N}";
    private readonly string _messageId = $"confirm-message-{Guid.NewGuid():N}";
    private ElementReference _dialog;

    [Parameter] public bool IsOpen { get; set; }

    [Parameter] public string Eyebrow { get; set; } = "Confirm action";

    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired] public string Message { get; set; } = string.Empty;

    [Parameter] public string ConfirmText { get; set; } = "Confirm";

    [Parameter] public string CancelText { get; set; } = "Cancel";

    [Parameter] public string BusyText { get; set; } = "Working…";

    [Parameter] public string ConfirmButtonId { get; set; } = "confirm-delete-btn";

    [Parameter] public string CancelButtonId { get; set; } = "cancel-delete-btn";

    [Parameter] public bool IsBusy { get; set; }

    [Parameter] public string? ErrorMessage { get; set; }

    [Parameter] public EventCallback OnConfirm { get; set; }

    [Parameter] public EventCallback OnCancel { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsOpen)
        {
            await Js.InvokeVoidAsync("foundryStudioDialog.focusAndTrap", _dialog);
        }
    }

    private async Task ConfirmAsync()
    {
        if (!IsBusy)
        {
            await OnConfirm.InvokeAsync();
        }
    }

    private async Task CancelAsync()
    {
        if (!IsBusy)
        {
            await OnCancel.InvokeAsync();
        }
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            await CancelAsync();
        }
    }
}
