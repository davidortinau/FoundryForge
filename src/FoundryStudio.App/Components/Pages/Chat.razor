@page "/chat"
@using System.Globalization
@using FoundryStudio.Core.Chat
@using Microsoft.Extensions.AI
@implements IDisposable
@inject IChatService ChatService
@inject IChatHistoryStore HistoryStore
@inject IFoundryCatalogService CatalogService
@inject NavigationManager Nav
@inject ConversationMemoryRetriever MemoryRetriever
@inject CompareOrchestrator _compareOrchestrator

<div class="chat-shell" data-testid="chat-page">
    <PageHeader TitleId="chat-title"
                Eyebrow="Local chat"
                Title="Chat with a loaded model"
                Subtitle="Stream replies in-process from Foundry Local. Every token and metric shown comes from the real stream." />

    <div class="chat-layout">
        <!-- LEFT: Thread list -->
        <aside class="chat-sidebar card" aria-label="Chat conversations and controls">
            <div class="chat-sidebar__actions">
                <button type="button"
                        class="button button-secondary"
                        data-testid="chat-new"
                        @onclick="NewChatAsync"
                        disabled="@IsStreaming">New chat</button>
            </div>

            <div class="field">
                <label class="visually-hidden" for="chat-search-input">Search conversations</label>
                <input id="chat-search-input"
                       type="search"
                       class="chat-search"
                       placeholder="Search…"
                       value="@_sessionSearch"
                       @oninput="OnSearchChanged" />
            </div>

            <nav class="chat-conversations" data-testid="chat-conversations" aria-label="Saved conversations">
                @{
                    var grouped = GetGroupedSessions().ToList();
                    if (!grouped.Any())
                    {
                        <p class="status">No conversations yet.</p>
                    }
                    else
                    {
                        foreach (var (label, groupSessions) in grouped)
                        {
                            <p class="chat-group-label eyebrow">@label</p>
                            foreach (var session in groupSessions)
                            {
                                var isActive = CurrentSession?.Id == session.Id;
                                <div class="chat-conversation-row @(isActive ? "is-active" : "")">
                                    @if (_renamingSessionId == session.Id)
                                    {
                                        <input type="text"
                                               class="chat-rename-input"
                                               value="@_renameValue"
                                               @onblur="() => CommitRenameAsync(session.Id)"
                                               @onkeydown="(e) => HandleRenameKeyAsync(e, session.Id)"
                                               @onclick:stopPropagation="true" />
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="chat-conversation @(isActive ? "is-active" : "")"
                                                aria-current="@(isActive ? "page" : null)"
                                                @onclick="() => SelectSessionAsync(session.Id)"
                                                @ondblclick="() => BeginRename(session)"
                                                disabled="@IsStreaming">
                                            <span>@session.Title</span>
                                            <small>@session.UpdatedAt.LocalDateTime.ToString("g", CultureInfo.CurrentCulture)</small>
                                        </button>
                                        <button type="button"
                                                class="icon-button chat-conv-menu-btn"
                                                aria-label="More options for @session.Title"
                                                @onclick="() => ToggleOverflow(session.Id)"
                                                @onclick:stopPropagation="true"
                                                disabled="@IsStreaming">
                                            <svg viewBox="0 0 16 16" aria-hidden="true"><circle cx="8" cy="3.5" r="1.3" fill="currentColor" stroke="none" /><circle cx="8" cy="8" r="1.3" fill="currentColor" stroke="none" /><circle cx="8" cy="12.5" r="1.3" fill="currentColor" stroke="none" /></svg>
                                        </button>
                                    }
                                    @if (_openOverflowId == session.Id)
                                    {
                                        <div class="chat-conv-menu" role="menu">
                                            <button type="button" class="chat-conv-menu-item"
                                                    data-testid="@(isActive ? "chat-duplicate" : null)"
                                                    @onclick="() => DuplicateSessionAsync(session.Id)">Duplicate</button>
                                            <hr class="chat-conv-menu-sep" />
                                            <button type="button" class="chat-conv-menu-item"
                                                    data-testid="@(isActive ? "chat-clear" : null)"
                                                    disabled="@IsStreaming"
                                                    @onclick="() => OpenClearForSessionAsync(session.Id)">Clear messages…</button>
                                            <button type="button" class="chat-conv-menu-item chat-conv-menu-item--danger"
                                                    data-testid="@(isActive ? "chat-delete" : null)"
                                                    disabled="@IsStreaming"
                                                    @onclick="() => OpenDeleteForSessionAsync(session.Id)">Delete chat…</button>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    }
                }
            </nav>
        </aside>

        <!-- RIGHT: State-driven main pane -->
        <main class="chat-main" aria-labelledby="chat-title">
            @if (!string.IsNullOrWhiteSpace(_busyMessage))
            {
                <section class="chat-state chat-state--busy card" data-testid="chat-busy" role="alert">
                    <strong>Model state changed.</strong>
                    <p>@_busyMessage</p>
                </section>
            }

            @if (ActiveModel is null)
            {
                @if (HasPastMessages)
                {
                    <!-- State B: no model loaded, but session has history — read-only -->
                    <section class="chat-workbench card" aria-label="Conversation history (read-only)">
                        <div class="chat-readonly-notice" role="note">
                            <span class="chat-readonly-notice__text">This conversation is read-only — no model is currently loaded.</span>
                            <button type="button" class="button" @onclick="NavigateToServe">Load a model to continue</button>
                        </div>
                        <div class="chat-messages chat-messages--readonly" data-testid="chat-messages" aria-label="Past conversation (read-only)">
                            @foreach (var message in VisibleMessages)
                            {
                                <MessageBubble Role="@message.Role" Content="@message.Content" IsReadOnly="true" />
                            }
                        </div>
                        <div class="chat-composer-panel">
                            <div class="field chat-composer-field">
                                <label for="chat-composer-input">Message</label>
                                <textarea id="chat-composer-input"
                                          data-testid="chat-composer"
                                          rows="4"
                                          placeholder="Load a model to start chatting"
                                          disabled="true"></textarea>
                            </div>
                            <div class="chat-composer-panel__actions">
                                <button type="button" class="button chat-send" data-testid="chat-send" disabled="true">Send</button>
                            </div>
                        </div>
                    </section>
                }
                else
                {
                    <!-- State A: no model, no history — empty state -->
                    <section class="chat-state card" data-testid="chat-gate" aria-labelledby="chat-gate-title">
                        <span class="foundry-mark" aria-hidden="true"><svg viewBox="0 0 24 24" focusable="false"><path d="M5 6.5h14v11H5z" /><path d="M8 17.5V9h8" /><path d="M8 12.75h6.5" /></svg></span>
                        <div>
                            <h2 id="chat-gate-title">Load a model to start chatting.</h2>
                            <p class="status">Load a local model from the Serve page (or click Load a model below), then start chatting.</p>
                        </div>
                        <button type="button" class="button" data-testid="chat-gate-load" @onclick="NavigateToServe">
                            Load a model
                        </button>
                    </section>
                }
            }
            else
            {
                <!-- State C: model loaded — live workbench -->
                <section class="chat-workbench card" aria-label="Conversation workbench">
                    <div class="chat-workbench__header">
                        @if (_loadedModels.Count > 1)
                        {
                            <select class="chat-model-switcher"
                                    data-testid="chat-active-model"
                                    aria-label="Active model — select to switch"
                                    @onchange="OnActiveModelChangedAsync">
                                @foreach (var m in _loadedModels)
                                {
                                    if (m.Alias == ActiveModel?.Alias)
                                    {
                                        <option value="@m.Alias" selected>@DisplayName(m) · loaded</option>
                                    }
                                    else
                                    {
                                        <option value="@m.Alias">@DisplayName(m) · loaded</option>
                                    }
                                }
                            </select>
                        }
                        else
                        {
                            <span class="chat-active-model-chip" data-testid="chat-active-model" aria-live="polite">@ActiveModelLabel</span>
                        }

                        <!-- Workbench mode segmented control -->
                        <div class="workbench-mode-tabs" role="group" aria-label="Workbench mode">
                            <button type="button"
                                    class="workbench-mode-tab @(_workbenchMode == WorkbenchMode.Chat ? "is-active" : "")"
                                    data-testid="workbench-mode-chat"
                                    aria-pressed="@(_workbenchMode == WorkbenchMode.Chat)"
                                    @onclick="() => _workbenchMode = WorkbenchMode.Chat">Chat</button>
                            <button type="button"
                                    class="workbench-mode-tab @(_workbenchMode == WorkbenchMode.Compare ? "is-active" : "")"
                                    data-testid="workbench-mode-compare"
                                    aria-pressed="@(_workbenchMode == WorkbenchMode.Compare)"
                                    @onclick="() => _workbenchMode = WorkbenchMode.Compare">Compare</button>
                        </div>
                    </div>

                    @if (_workbenchMode == WorkbenchMode.Chat)
                    {
                    <div class="chat-messages" data-testid="chat-messages" aria-label="Conversation messages">
                        @{
                            var visibleMessages = VisibleMessages;
                            if (visibleMessages.Count > 0)
                            {
                                for (var msgIdx = 0; msgIdx < visibleMessages.Count; msgIdx++)
                                {
                                    var message = visibleMessages[msgIdx];
                                    var capturedIdx = msgIdx;
                                    var retryPrompt = (message.Role == ChatTurnRole.Assistant && capturedIdx > 0 && visibleMessages[capturedIdx - 1].Role == ChatTurnRole.User)
                                        ? visibleMessages[capturedIdx - 1].Content : null;
                                    <MessageBubble Role="@message.Role"
                                                   Content="@message.Content"
                                                   OnRetry="() => RetryAsync(retryPrompt)" />
                                    @if (message.Role == ChatTurnRole.Assistant && message.Metrics is not null)
                                    {
                                        var showMetrics = message.StopReason is not StopReason.Error
                                                          and not StopReason.UserCancelled
                                                          and not null
                                                          && !IsGarbledContent(message.Content);
                                        <MetricsRow Metrics="@message.Metrics" ShouldShow="@showMetrics" />
                                    }
                                }
                            }
                            else
                            {
                                <p class="chat-empty status">Ask this local model to start a conversation.</p>
                            }
                        }

                        @if (IsStreaming)
                        {
                            @if (!_hasFirstToken)
                            {
                                <p class="chat-awaiting" data-testid="chat-awaiting" role="status" aria-live="polite">Waiting for the first token…</p>
                            }
                            <MessageBubble Role="ChatTurnRole.Assistant" Content="@_liveAssistantText" IsStreaming="true" />
                            <MetricsRow Metrics="@_liveMetrics" ShouldShow="true" />
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_streamError))
                    {
                        <p class="operation-error" data-testid="chat-error" role="alert">@_streamError</p>
                    }

                    <div class="chat-composer-panel">
                        <ChatMemorySuggestions Suggestions="@_memorySuggestions"
                                               IncludedIds="@_memoryIncludedIds"
                                               OnToggle="@ToggleMemoryItem" />
                        <div class="field chat-composer-field">
                            <label for="chat-composer-input">Message</label>
                            <textarea id="chat-composer-input"
                                      data-testid="chat-composer"
                                      rows="4"
                                      placeholder="Ask this local model…"
                                      value="@_draft"
                                      @oninput="OnDraftChanged"
                                      disabled="@IsStreaming"></textarea>
                        </div>
                        <div class="chat-composer-panel__actions">
                            @if (IsStreaming)
                            {
                                <button type="button" class="button button-secondary" data-testid="chat-stop" @onclick="StopStreamingAsync">Stop</button>
                            }
                            else
                            {
                                <button type="button" class="button chat-send" data-testid="chat-send" @onclick="SendAsync" disabled="@(!CanSend)">Send</button>
                            }
                        </div>
                    </div>
                    }
                    else
                    {
                        <CompareView LoadedModels="_loadedModels" Orchestrator="_compareOrchestrator" />
                    }
                </section>
            }

            @if (_workbenchMode == WorkbenchMode.Chat && ActiveModel is not null)
            {
            <section class="chat-settings-grid" aria-label="Chat prompt and inference settings">
                <div class="card chat-system-card">
                    <div class="field">
                        <label for="chat-system-prompt-input">System prompt</label>
                        <textarea id="chat-system-prompt-input"
                                  data-testid="chat-system-prompt"
                                  rows="5"
                                  value="@(CurrentSession?.SystemPrompt ?? string.Empty)"
                                  @onchange="OnSystemPromptChangedAsync"
                                  disabled="@(CurrentSession is null || IsStreaming)"
                                  placeholder="Optional instructions for this conversation"></textarea>
                    </div>
                </div>

                <div class="card chat-params-card" aria-label="Supported inference parameters">
                    <p class="eyebrow">Inference parameters</p>
                    <div class="chat-params-grid">
                        <div class="field">
                            <label for="param-temperature-input">Temperature</label>
                            <input id="param-temperature-input" data-testid="param-temperature" type="number" min="0" max="2" step="0.1" value="@FormatDouble(CurrentParameters.Temperature)" @onchange="OnTemperatureChangedAsync" disabled="@(CurrentSession is null || IsStreaming)" />
                        </div>
                        <div class="field">
                            <label for="param-max-tokens-input">Max tokens</label>
                            <input id="param-max-tokens-input" data-testid="param-max-tokens" type="number" min="1" step="1" value="@FormatInt(CurrentParameters.MaxOutputTokens)" @onchange="OnMaxTokensChangedAsync" disabled="@(CurrentSession is null || IsStreaming)" />
                        </div>
                        <div class="field">
                            <label for="param-top-p-input">Top-p</label>
                            <input id="param-top-p-input" data-testid="param-top-p" type="number" min="0" max="1" step="0.05" value="@FormatDouble(CurrentParameters.TopP)" @onchange="OnTopPChangedAsync" disabled="@(CurrentSession is null || IsStreaming)" />
                        </div>
                    </div>
                </div>

                <div class="card chat-context-card">
                    <p class="eyebrow">Context window</p>
                    <div class="chat-context" data-testid="chat-context" aria-label="Estimated context window usage">
                        @if (ContextEstimate.IsUnknown)
                        {
                            <p data-testid="chat-context-unknown">About @ContextEstimate.UsedTokensEstimate.ToString("N0", CultureInfo.CurrentCulture) tokens used; context limit unknown for this model.</p>
                        }
                        else
                        {
                            <p>About @ContextEstimate.UsedTokensEstimate.ToString("N0", CultureInfo.CurrentCulture) of @ContextEstimate.ContextLength!.Value.ToString("N0", CultureInfo.CurrentCulture) tokens used (@FormatPercent(ContextEstimate.Fraction)).</p>
                        }
                        @if (ContextEstimate.IsWarn)
                        {
                            <p class="chat-context__warn" data-testid="chat-context-warn" role="status">Near the estimated limit — older turns may fall out of context.</p>
                        }
                    </div>
                </div>
            </section>
            }
        </main>
    </div>

    <ConfirmDialog IsOpen="@(_confirmAction is not null)"
                   Eyebrow="Chat history"
                   Title="@ConfirmTitle"
                   Message="@ConfirmMessage"
                   ConfirmText="@ConfirmText"
                   BusyText="Working…"
                   IsBusy="@_confirmBusy"
                   ErrorMessage="@_confirmError"
                   OnConfirm="ConfirmDestructiveAsync"
                   OnCancel="CloseConfirmDialogAsync" />
</div>

@code {
    private IReadOnlyList<ChatSession> _sessions = Array.Empty<ChatSession>();
    private IReadOnlyList<ModelInfo> _loadedModels = Array.Empty<ModelInfo>();
    private ChatSession? CurrentSession { get; set; }
    private ModelInfo? ActiveModel { get; set; }
    private string _draft = string.Empty;
    private string _liveAssistantText = string.Empty;
    private GenerationMetrics? _liveMetrics;
    private bool _hasFirstToken;
    private bool _isStreaming;
    private string? _busyMessage;
    private string? _streamError;
    private CancellationTokenSource? _streamCts;
    private ConfirmAction? _confirmAction;
    private string? _confirmTargetId;
    private bool _confirmBusy;
    private string? _confirmError;
    private string _sessionSearch = string.Empty;
    private string? _renamingSessionId;
    private string _renameValue = string.Empty;
    private string? _openOverflowId;

    // Phase 5 — cross-session memory
    private IReadOnlyList<MemorySnippet> _memorySuggestions = Array.Empty<MemorySnippet>();
    private HashSet<string> _memoryIncludedIds = new();

    private enum ConfirmAction { Clear, Delete }

    /// <summary>Which workbench surface is active: the normal Chat, or the side-by-side Compare.</summary>
    private enum WorkbenchMode { Chat, Compare }

    private WorkbenchMode _workbenchMode = WorkbenchMode.Chat;

    private bool IsStreaming => _isStreaming;

    private bool CanSend => ActiveModel is not null && !IsStreaming && !string.IsNullOrWhiteSpace(_draft);

    private InferenceParameters CurrentParameters => CurrentSession?.Parameters ?? InferenceParameters.Defaults;

    private bool HasPastMessages => CurrentSession?.Messages.Any(m => m.Role is ChatTurnRole.User or ChatTurnRole.Assistant) == true;

    private IReadOnlyList<ChatMessageRecord> VisibleMessages =>
        CurrentSession?.Messages.Where(m => m.Role is ChatTurnRole.User or ChatTurnRole.Assistant).ToList()
        ?? (IReadOnlyList<ChatMessageRecord>)Array.Empty<ChatMessageRecord>();

    private string ActiveModelLabel => ActiveModel is null
        ? "No model loaded"
        : $"{DisplayName(ActiveModel)} · loaded";

    private string ConfirmTitle => _confirmAction switch
    {
        ConfirmAction.Clear => "Clear conversation messages?",
        ConfirmAction.Delete => "Delete conversation?",
        _ => string.Empty
    };

    private string ConfirmText => _confirmAction switch
    {
        ConfirmAction.Clear => "Clear messages",
        ConfirmAction.Delete => "Delete chat",
        _ => "Confirm"
    };

    private string ConfirmMessage
    {
        get
        {
            var targetTitle = _sessions.FirstOrDefault(s => s.Id == _confirmTargetId)?.Title ?? "this conversation";
            return _confirmAction switch
            {
                ConfirmAction.Clear => $"Clear all messages in '{targetTitle}'? This cannot be undone.",
                ConfirmAction.Delete => $"Delete conversation '{targetTitle}'? This cannot be undone.",
                _ => string.Empty
            };
        }
    }

    private ContextWindowEstimate ContextEstimate
    {
        get
        {
            var used = 0;
            if (!string.IsNullOrWhiteSpace(CurrentSession?.SystemPrompt))
                used += ContextWindowEstimator.ApproximateTokens(CurrentSession.SystemPrompt);

            if (CurrentSession is not null)
                used += CurrentSession.Messages.Sum(m => ContextWindowEstimator.ApproximateTokens(m.Content));

            if (IsStreaming)
                used += ContextWindowEstimator.ApproximateTokens(_liveAssistantText);

            return ContextWindowEstimator.Estimate(used, ActiveModel?.ContextLength);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await RefreshLoadedModelAsync();
        await RefreshSessionsAsync();
        if (CurrentSession is null)
            await NewChatAsync();
    }

    private async Task RefreshLoadedModelAsync()
    {
        try
        {
            var loaded = await CatalogService.ListLoadedAsync();
            _loadedModels = loaded.OrderBy(m => m.DisplayName, StringComparer.OrdinalIgnoreCase).ToList();
            if (ActiveModel is not null && _loadedModels.Any(m => m.Alias == ActiveModel.Alias))
                ActiveModel = _loadedModels.First(m => m.Alias == ActiveModel.Alias);
            else
                ActiveModel = _loadedModels.FirstOrDefault();
            _busyMessage = null;
        }
        catch (Exception ex)
        {
            _loadedModels = Array.Empty<ModelInfo>();
            ActiveModel = null;
            _busyMessage = $"Loaded model state could not be read: {ex.Message}";
        }
    }

    private async Task RefreshSessionsAsync()
    {
        _sessions = await HistoryStore.ListAsync();
        _sessions = _sessions.OrderByDescending(s => s.UpdatedAt).ToList();
        if (CurrentSession is not null)
            CurrentSession = _sessions.FirstOrDefault(s => s.Id == CurrentSession.Id) ?? CurrentSession;
        else
            CurrentSession = _sessions.FirstOrDefault();
    }

    private async Task NewChatAsync()
    {
        var now = DateTimeOffset.UtcNow;
        CurrentSession = ChatSession.New(now);
        await HistoryStore.SaveAsync(CurrentSession);
        await RefreshSessionsAsync();
    }

    private IEnumerable<(string Label, IReadOnlyList<ChatSession> Sessions)> GetGroupedSessions()
    {
        var filtered = string.IsNullOrWhiteSpace(_sessionSearch)
            ? _sessions
            : _sessions.Where(s => s.Title.Contains(_sessionSearch, StringComparison.OrdinalIgnoreCase)).ToList();

        var today = DateTimeOffset.Now.LocalDateTime.Date;
        var yesterday = today.AddDays(-1);

        var groups = filtered.GroupBy(s =>
        {
            var date = s.UpdatedAt.LocalDateTime.Date;
            if (date >= today) return "Today";
            if (date >= yesterday) return "Yesterday";
            return "Earlier";
        });

        foreach (var label in new[] { "Today", "Yesterday", "Earlier" })
        {
            var group = groups.FirstOrDefault(g => g.Key == label);
            if (group is not null)
                yield return (label, group.ToList());
        }
    }

    private void OnSearchChanged(ChangeEventArgs args) => _sessionSearch = args.Value?.ToString() ?? string.Empty;

    private void BeginRename(ChatSession session)
    {
        _renamingSessionId = session.Id;
        _renameValue = session.Title;
        _openOverflowId = null;
    }

    private async Task CommitRenameAsync(string id)
    {
        if (_renamingSessionId != id) return;
        _renamingSessionId = null;
        var newTitle = _renameValue.Trim();
        if (string.IsNullOrEmpty(newTitle)) { await InvokeAsync(StateHasChanged); return; }

        var session = await HistoryStore.GetAsync(id);
        if (session is null) { await InvokeAsync(StateHasChanged); return; }

        var updated = session with { Title = newTitle, UpdatedAt = DateTimeOffset.UtcNow };
        await HistoryStore.SaveAsync(updated);
        if (CurrentSession?.Id == id) CurrentSession = updated;
        await RefreshSessionsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleRenameKeyAsync(KeyboardEventArgs e, string id)
    {
        if (e.Key == "Enter") await CommitRenameAsync(id);
        else if (e.Key == "Escape") { _renamingSessionId = null; await InvokeAsync(StateHasChanged); }
    }

    private void ToggleOverflow(string id) => _openOverflowId = _openOverflowId == id ? null : id;

    private async Task DuplicateSessionAsync(string id)
    {
        _openOverflowId = null;
        var source = await HistoryStore.GetAsync(id) ?? CurrentSession;
        if (source is null) return;

        var now = DateTimeOffset.UtcNow;
        var copy = source with
        {
            Id = Guid.NewGuid().ToString("n"),
            Title = $"Copy of {source.Title}",
            CreatedAt = now,
            UpdatedAt = now,
            Messages = source.Messages.ToList()
        };
        await HistoryStore.SaveAsync(copy);
        CurrentSession = copy;
        await RefreshSessionsAsync();
    }

    private Task OpenClearForSessionAsync(string id)
    {
        _openOverflowId = null;
        _confirmTargetId = id;
        _confirmAction = ConfirmAction.Clear;
        _confirmError = null;
        return InvokeAsync(StateHasChanged);
    }

    private Task OpenDeleteForSessionAsync(string id)
    {
        _openOverflowId = null;
        _confirmTargetId = id;
        _confirmAction = ConfirmAction.Delete;
        _confirmError = null;
        return InvokeAsync(StateHasChanged);
    }

    private async Task SelectSessionAsync(string id)
    {
        if (IsStreaming) return;
        _openOverflowId = null;
        CurrentSession = await HistoryStore.GetAsync(id) ?? CurrentSession;
        _draft = string.Empty;
        _streamError = null;
        await InvokeAsync(StateHasChanged);
    }

    private void NavigateToServe() => Nav.NavigateTo("/server");

    private async Task OnActiveModelChangedAsync(ChangeEventArgs args)
    {
        var alias = args.Value?.ToString();
        if (alias is null) return;
        ActiveModel = _loadedModels.FirstOrDefault(m => m.Alias == alias) ?? ActiveModel;
        await InvokeAsync(StateHasChanged);
    }

    private void OnDraftChanged(ChangeEventArgs args)
    {
        _draft = args.Value?.ToString() ?? string.Empty;
        RefreshMemorySuggestions();
    }

    private void RefreshMemorySuggestions()
    {
        if (string.IsNullOrWhiteSpace(_draft) || _sessions.Count <= 1)
        {
            _memorySuggestions = Array.Empty<MemorySnippet>();
            return;
        }

        _memorySuggestions = MemoryRetriever.Retrieve(
            query: _draft,
            sessions: _sessions,
            excludeSessionId: CurrentSession?.Id,
            topK: 3);

        // Remove any included IDs that are no longer in the new suggestion set.
        _memoryIncludedIds.IntersectWith(_memorySuggestions.Select(s => s.SessionId));
    }

    private void ToggleMemoryItem(string sessionId)
    {
        if (!_memoryIncludedIds.Add(sessionId))
            _memoryIncludedIds.Remove(sessionId);
        StateHasChanged();
    }

    private async Task SendAsync()
    {
        if (!CanSend || CurrentSession is null || ActiveModel is null) return;

        await RefreshLoadedModelAsync();
        if (ActiveModel is null)
        {
            _busyMessage = "The model is no longer loaded. Load a model before sending.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var userText = _draft.Trim();
        _draft = string.Empty;
        _streamError = null;
        _busyMessage = null;
        _liveAssistantText = string.Empty;
        _liveMetrics = null;
        _hasFirstToken = false;
        _isStreaming = true;
        _streamCts = new CancellationTokenSource();
        var sentAt = DateTimeOffset.UtcNow;
        var accumulator = new TokenStatsAccumulator();
        accumulator.OnSend(sentAt);

        CurrentSession = AddMessage(CurrentSession, new ChatMessageRecord(ChatTurnRole.User, userText, sentAt));
        if (CurrentSession.Title == "New chat")
            CurrentSession = CurrentSession with { Title = DeriveTitle(userText), UpdatedAt = sentAt };
        CurrentSession = CurrentSession with { ModelAlias = ActiveModel.Alias, UpdatedAt = sentAt };
        await InvokeAsync(StateHasChanged);

        StopReason stopReason = StopReason.Unknown;
        try
        {
            // Phase 5: if the user explicitly included memory snippets, assemble them as a clearly-
            // delimited context note prepended after the system prompt. Only included items are
            // injected — what the user sees in the UI is exactly what the model receives (honesty rule).
            string? memoryContext = null;
            if (_memoryIncludedIds.Count > 0)
            {
                var included = _memorySuggestions
                    .Where(s => _memoryIncludedIds.Contains(s.SessionId))
                    .ToList();
                if (included.Count > 0)
                    memoryContext = BuildMemoryContextNote(included);
            }

            var requestMessages = TranscriptAssembler.Assemble(CurrentSession, memoryContext);
            var options = CurrentSession.Parameters.ToChatOptions(ActiveModel.Alias);
            await foreach (var update in ChatService.StreamAsync(requestMessages, options, _streamCts.Token).WithCancellation(_streamCts.Token))
            {
                accumulator.OnUpdate(update, DateTimeOffset.UtcNow);
                stopReason = MapStopReason(update.FinishReason) ?? stopReason;
                if (!string.IsNullOrEmpty(update.Text))
                {
                    _hasFirstToken = true;
                    _liveAssistantText += update.Text;
                    _liveMetrics = accumulator.Complete(MapStopReason(update.FinishReason) ?? StopReason.Unknown);
                    await InvokeAsync(StateHasChanged);

                    // Auto-stop a runaway garbled stream. Some model/runtime combinations degenerate into an
                    // endless run of replacement/'?' characters; without this the user must stop it by hand.
                    // Once there's enough output to judge and it's overwhelmingly unreadable, cancel so the
                    // model actually stops generating; the partial text renders as the honest "unreadable"
                    // state (MessageBubble.IsGarbled).
                    if (IsRunawayGarble(_liveAssistantText))
                    {
                        stopReason = StopReason.Error;
                        _streamCts.Cancel();
                        break;
                    }
                }
            }
        }
        catch (OperationCanceledException) when (_streamCts.IsCancellationRequested)
        {
            stopReason = StopReason.UserCancelled;
        }
        catch (ModelBusyException ex)
        {
            stopReason = StopReason.Error;
            _busyMessage = $"The model is busy or was unloaded elsewhere: {ex.Message}";
        }
        catch (Exception ex)
        {
            stopReason = StopReason.Error;
            _streamError = $"Stream stopped with an error. Partial response is preserved. {ex.Message}";
        }
        finally
        {
            var completedAt = DateTimeOffset.UtcNow;
            _isStreaming = false;
            var metrics = accumulator.Complete(stopReason);
            if (CurrentSession is not null)
            {
                CurrentSession = AddMessage(CurrentSession, new ChatMessageRecord(ChatTurnRole.Assistant, _liveAssistantText, completedAt, metrics, stopReason));
                CurrentSession = CurrentSession with { UpdatedAt = completedAt, ModelAlias = ActiveModel?.Alias ?? CurrentSession.ModelAlias };
                await HistoryStore.SaveAsync(CurrentSession);
                await RefreshSessionsAsync();
            }

            _streamCts?.Dispose();
            _streamCts = null;
            _liveAssistantText = string.Empty;
            _liveMetrics = null;
            _hasFirstToken = false;
            // Clear memory state after each send; fresh retrieval on next draft.
            _memorySuggestions = Array.Empty<MemorySnippet>();
            _memoryIncludedIds.Clear();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RetryAsync(string? prompt)
    {
        if (string.IsNullOrWhiteSpace(prompt) || ActiveModel is null) return;
        _draft = prompt;
        await SendAsync();
    }

    // Detect a runaway garbled stream: enough output to judge, and overwhelmingly '?'/replacement chars.
    // Mirrors MessageBubble.IsGarbled but gates on a minimum length so a brief early run never false-trips.
    private static bool IsRunawayGarble(string content)
    {
        if (string.IsNullOrEmpty(content)) return false;
        var nonSpace = content.Count(c => c != ' ' && c != '\t' && c != '\n' && c != '\r');
        if (nonSpace < 48) return false;
        var bad = content.Count(c => c == '?' || c == '\uFFFD');
        return (double)bad / nonSpace > 0.6;
    }

    private Task StopStreamingAsync()
    {
        _streamCts?.Cancel();
        return InvokeAsync(StateHasChanged);
    }

    private async Task OnSystemPromptChangedAsync(ChangeEventArgs args)
    {
        if (CurrentSession is null) return;
        CurrentSession = CurrentSession with
        {
            SystemPrompt = NormalizeOptional(args.Value?.ToString()),
            UpdatedAt = DateTimeOffset.UtcNow
        };
        await SaveCurrentSessionAsync();
    }

    private Task OnTemperatureChangedAsync(ChangeEventArgs args) => UpdateParametersAsync(CurrentParameters with { Temperature = ParseDouble(args.Value?.ToString()) });

    private Task OnMaxTokensChangedAsync(ChangeEventArgs args) => UpdateParametersAsync(CurrentParameters with { MaxOutputTokens = ParseInt(args.Value?.ToString()) });

    private Task OnTopPChangedAsync(ChangeEventArgs args) => UpdateParametersAsync(CurrentParameters with { TopP = ParseDouble(args.Value?.ToString()) });

    private async Task UpdateParametersAsync(InferenceParameters parameters)
    {
        if (CurrentSession is null) return;
        CurrentSession = CurrentSession with { Parameters = parameters, UpdatedAt = DateTimeOffset.UtcNow };
        await SaveCurrentSessionAsync();
    }

    private async Task SaveCurrentSessionAsync()
    {
        if (CurrentSession is null) return;
        await HistoryStore.SaveAsync(CurrentSession);
        await RefreshSessionsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmDestructiveAsync()
    {
        if (_confirmTargetId is null || _confirmAction is null) return;

        _confirmBusy = true;
        _confirmError = null;
        var targetId = _confirmTargetId;
        try
        {
            if (_confirmAction == ConfirmAction.Clear)
            {
                await HistoryStore.ClearMessagesAsync(targetId, userConfirmed: true);
                if (CurrentSession?.Id == targetId)
                    CurrentSession = await HistoryStore.GetAsync(targetId) ?? CurrentSession with { Messages = Array.Empty<ChatMessageRecord>(), UpdatedAt = DateTimeOffset.UtcNow };
            }
            else
            {
                await HistoryStore.DeleteAsync(targetId, userConfirmed: true);
                if (CurrentSession?.Id == targetId) CurrentSession = null;
            }

            _confirmAction = null;
            _confirmBusy = false;
            _confirmTargetId = null;
            await RefreshSessionsAsync();
            if (CurrentSession is null) await NewChatAsync();
        }
        catch (Exception ex)
        {
            _confirmError = ex.Message;
            _confirmBusy = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private Task CloseConfirmDialogAsync()
    {
        _confirmAction = null;
        _confirmBusy = false;
        _confirmError = null;
        return InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Detects non-renderable output: empty after trim, or dominated by replacement characters
    /// (U+FFFD / '?') — more than 60% of non-whitespace chars are bad.
    /// </summary>
    private static bool IsGarbledContent(string content)
    {
        var trimmed = content.Trim();
        if (string.IsNullOrEmpty(trimmed)) return true;
        var nonSpace = trimmed.Count(c => c != ' ' && c != '\t' && c != '\n' && c != '\r');
        if (nonSpace == 0) return true;
        var badChars = trimmed.Count(c => c == '?' || c == '\uFFFD');
        return (double)badChars / nonSpace > 0.6;
    }

    /// <summary>
    /// Builds the memory context string injected into the model request (Phase 5). What is built
    /// here is exactly what the user sees checked in the UI — the honesty constraint.
    /// </summary>
    private static string BuildMemoryContextNote(IEnumerable<MemorySnippet> snippets)
    {
        var sb = new System.Text.StringBuilder();
        foreach (var s in snippets)
        {
            sb.AppendLine($"[From \"{s.SessionTitle}\"]");
            sb.AppendLine(s.Snippet);
            sb.AppendLine();
        }
        return sb.ToString().TrimEnd();
    }

    private static ChatSession AddMessage(ChatSession session, ChatMessageRecord message)
    {
        var messages = session.Messages.ToList();
        messages.Add(message);
        return session with { Messages = messages, UpdatedAt = message.CreatedAt };
    }

    private static StopReason? MapStopReason(ChatFinishReason? reason)
    {
        if (reason is null) return null;
        if (reason == ChatFinishReason.Stop) return StopReason.Natural;
        if (reason == ChatFinishReason.Length) return StopReason.MaxTokens;
        if (reason == ChatFinishReason.ToolCalls) return StopReason.ToolCalls;
        return StopReason.Unknown;
    }

    private static string DisplayName(ModelInfo model) =>
        string.IsNullOrWhiteSpace(model.DisplayName) ? model.Alias : model.DisplayName;

    private static string DeriveTitle(string text) =>
        text.Length <= 48 ? text : text[..48].TrimEnd() + "…";

    private static string? NormalizeOptional(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static double? ParseDouble(string? value) =>
        double.TryParse(value, NumberStyles.Float, CultureInfo.InvariantCulture, out var parsed) ? parsed : null;

    private static int? ParseInt(string? value) =>
        int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed) ? parsed : null;

    private static string FormatDouble(double? value) =>
        value?.ToString("0.###", CultureInfo.InvariantCulture) ?? string.Empty;

    private static string FormatInt(int? value) =>
        value?.ToString(CultureInfo.InvariantCulture) ?? string.Empty;

    private static string FormatPercent(double? value) =>
        value is null ? "unknown" : value.Value.ToString("P0", CultureInfo.CurrentCulture);

    public void Dispose()
    {
        _streamCts?.Cancel();
        _streamCts?.Dispose();
        // Synchronously cancel any in-flight compare run (no async in Dispose).
        _compareOrchestrator.Cancel();
    }
}
