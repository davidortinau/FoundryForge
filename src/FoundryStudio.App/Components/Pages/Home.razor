@page "/"
@inject IFoundryCatalogService CatalogService
@inject ISettingsService SettingsService
@inject NavigationManager Navigation
@inject StartupNavigationService StartupNav
@inject IJSRuntime JS

<div class="catalog-shell" data-testid="catalog-page">
    <PageHeader TitleId="catalog-title"
                Eyebrow=""
                Title="Browse models"
                Subtitle="Install, load, and manage local models." />

    @if (_state.Status == CatalogViewState.CatalogStatus.Loading)
    {
        <section class="catalog-state card" data-testid="catalog-loading" role="status" aria-live="polite" aria-label="Loading catalog">
            <h2>Loading catalog…</h2>
            <p class="status">Reading the Foundry Local catalog through the app service.</p>
        </section>
    }
    else if (_state.Status == CatalogViewState.CatalogStatus.Error)
    {
        <section class="catalog-state card catalog-state--error" data-testid="catalog-error" role="alert" aria-label="Catalog load failed">
            <h2>Catalog could not be loaded</h2>
            <p>@_state.ErrorMessage</p>
            <button id="catalog-retry" type="button" class="button" @onclick="RefreshCatalogAsync">Retry</button>
        </section>
    }
    else
    {
        <!-- Toolbar: search (always visible) + collapsible filter drawer -->
        <section class="catalog-controls card" aria-label="Catalog search, filters, and view controls">
            <div class="catalog-controls__search-row">
                <div class="field field-search">
                    <label for="catalog-search">Search models</label>
                    <input id="catalog-search"
                           type="search"
                           value="@_state.Filter.SearchText"
                           @oninput="OnSearchChangedAsync"
                           placeholder="Alias, display name, or id"
                           autocomplete="off" />
                </div>
                <button type="button"
                        class="catalog-filters-toggle icon-button @(_filtersOpen ? "is-active" : string.Empty)"
                        aria-expanded="@_filtersOpen.ToString().ToLowerInvariant()"
                        aria-controls="catalog-filters-drawer"
                        title="@(_filtersOpen ? "Hide filters" : "Show filters")"
                        @onclick="ToggleFilters">
                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M4 6h16M7 12h10M10 18h4" /></svg>
                    @if (ActiveFilterCount > 0)
                    {
                        <span class="filter-active-count" aria-label="@ActiveFilterCount active filter@(ActiveFilterCount == 1 ? "" : "s")">@ActiveFilterCount</span>
                    }
                </button>
            </div>

            @if (_filtersOpen)
            {
                <div id="catalog-filters-drawer" class="catalog-filters-drawer" role="group" aria-label="Filters">
                    <div class="field">
                        <label for="filter-device">Device</label>
                        <select id="filter-device" value="@DeviceFilterValue" @onchange="OnDeviceChangedAsync">
                            <option value="">All devices</option>
                            @foreach (var device in _state.Facets.Devices)
                            {
                                <option value="@device">@device.ToString().ToUpperInvariant()</option>
                            }
                        </select>
                    </div>

                    <div class="field">
                        <label for="filter-task">Task</label>
                        <select id="filter-task" value="@(_state.Filter.Task ?? string.Empty)" @onchange="OnTaskChangedAsync">
                            <option value="">All tasks</option>
                            @foreach (var task in _state.Facets.Tasks)
                            {
                                <option value="@task">@task</option>
                            }
                        </select>
                    </div>

                    <div class="field">
                        <label for="filter-provider">Provider</label>
                        <select id="filter-provider" value="@(_state.Filter.Provider ?? string.Empty)" @onchange="OnProviderChangedAsync">
                            <option value="">All providers</option>
                            @foreach (var provider in _state.Facets.Providers)
                            {
                                <option value="@provider">@provider</option>
                            }
                        </select>
                    </div>

                    <div class="field field-checkbox">
                        <input id="filter-cached"
                               type="checkbox"
                               checked="@_state.Filter.CachedOnly"
                               @onchange="OnCachedOnlyChangedAsync" />
                        <label for="filter-cached">Cached only</label>
                    </div>

                    <div class="field">
                        <label for="view-toggle">Catalog view</label>
                        <select id="view-toggle" value="@_state.ViewMode" @onchange="OnViewModeChangedAsync">
                            <option value="@CatalogViewState.CatalogViewMode.Curated">Curated</option>
                            <option value="@CatalogViewState.CatalogViewMode.Full">Full catalog</option>
                        </select>
                    </div>
                </div>
            }
        </section>

        <section class="catalog-summary" aria-label="Catalog result summary">
            @if (_state.IsShowingCurated)
            {
                <p class="curated-banner" data-testid="curated-banner">Recommended — curated by FoundryStudio, not a quality ranking</p>
            }
            <span class="visually-hidden" data-testid="loaded-indicator" aria-live="polite">@LoadedSummary</span>
            <div class="catalog-summary__end">
                <p class="catalog-count" data-testid="catalog-count" aria-live="polite">
                    @_state.Visible.Count.ToString("N0") model@(_state.Visible.Count == 1 ? string.Empty : "s") shown
                    <span class="metadata-secondary">from @_state.AllModels.Count.ToString("N0") available</span>
                </p>
                <button id="catalog-refresh"
                        data-testid="refresh-catalog"
                        type="button"
                        class="icon-button catalog-refresh"
                        aria-label="Refresh catalog"
                        title="Refresh catalog"
                        @onclick="RefreshCatalogAsync"
                        disabled="@IsBusy">
                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M20 11a8 8 0 1 0-.5 4" /><path d="M20 5v6h-6" /></svg>
                </button>
            </div>
        </section>

        @if (_state.Status == CatalogViewState.CatalogStatus.Empty)
        {
            <section class="catalog-state card" data-testid="catalog-empty" role="status" aria-live="polite" aria-label="No matching catalog models">
                <span class="foundry-mark catalog-empty__mark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false"><path d="M5 6.5h14v11H5z" /><path d="M8 17.5V9h8" /><path d="M8 12.75h6.5" /></svg>
                </span>
                <h2>Choose your first model</h2>
                <p class="status">Try a different search, broaden the facets, or reset to the curated default.</p>
                <button id="catalog-reset" type="button" class="button" @onclick="ResetCatalogAsync">Reset filters</button>
            </section>
        }
        else
        {
            <!-- Two-pane layout: compact list (left) + detail panel (right) -->
            <div class="models-layout @(!DetailPanelVisible ? "models-layout--no-detail" : string.Empty)">
                <!-- LEFT: compact model list -->
                <div class="models-list" role="listbox" aria-label="Model list">
                    <section class="catalog-group models-list__group" data-testid="group-cached" aria-labelledby="group-cached-title">
                        <div class="catalog-group__header">
                            <h2 id="group-cached-title" data-testid="group-label"><span>Installed / cached</span>Ready on this Mac</h2>
                            <span data-testid="group-count" aria-live="polite">@_state.VisibleCached.Count.ToString("N0")</span>
                        </div>
                        @if (_state.VisibleCached.Count == 0)
                        {
                            <p class="status models-list__empty-group">No cached models match this view.</p>
                        }
                        else
                        {
                            @foreach (var model in _state.VisibleCached)
                            {
                                <button type="button"
                                        class="model-row @(IsSelected(model) ? "model-row--selected" : string.Empty) @(_state.IsLoaded(model) ? "model-row--loaded" : string.Empty)"
                                        role="option"
                                        aria-selected="@IsSelected(model).ToString().ToLowerInvariant()"
                                        data-alias="@model.Alias"
                                        title="@RowHoverTitle(model)"
                                        @onclick="() => SelectModelAsync(model)">
                                    <span class="model-row__name">
                                        <span class="model-row__displayname">@RowDisplayName(model)</span>
                                        <span class="model-row__alias">@model.Alias</span>
                                    </span>
                                    <span class="model-row__meta">
                                        @if (!string.IsNullOrWhiteSpace(model.ModelType))
                                        {
                                            <span class="format-badge model-row__format">@model.ModelType.Trim()</span>
                                        }
                                        @if (model.ContextLength is > 0)
                                        {
                                            <span class="model-row__context" title="Context length">@FormatContextK(model.ContextLength.Value)</span>
                                        }
                                        @if (model.SizeGb is > 0)
                                        {
                                            <span class="model-row__size">@model.SizeGb!.Value.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture) GB</span>
                                        }
                                        <ModelStateBadge IsCached="_state.IsCached(model)"
                                                         IsLoaded="_state.IsLoaded(model)" />
                                    </span>
                                </button>
                            }
                        }
                    </section>

                    <section class="catalog-group models-list__group" data-testid="group-available" aria-labelledby="group-available-title">
                        <div class="catalog-group__header">
                            <h2 id="group-available-title" data-testid="group-label"><span>Available to download</span>Not yet on this Mac</h2>
                            <span data-testid="group-count" aria-live="polite">@_state.VisibleAvailable.Count.ToString("N0")</span>
                        </div>
                        @if (_state.VisibleAvailable.Count == 0)
                        {
                            <p class="status models-list__empty-group">No available models match this view.</p>
                        }
                        else
                        {
                            @foreach (var model in _state.VisibleAvailable)
                            {
                                <button type="button"
                                        class="model-row @(IsSelected(model) ? "model-row--selected" : string.Empty)"
                                        role="option"
                                        aria-selected="@IsSelected(model).ToString().ToLowerInvariant()"
                                        data-alias="@model.Alias"
                                        title="@RowHoverTitle(model)"
                                        @onclick="() => SelectModelAsync(model)">
                                    <span class="model-row__name">
                                        <span class="model-row__displayname">@RowDisplayName(model)</span>
                                        <span class="model-row__alias">@model.Alias</span>
                                    </span>
                                    <span class="model-row__meta">
                                        @if (!string.IsNullOrWhiteSpace(model.ModelType))
                                        {
                                            <span class="format-badge model-row__format">@model.ModelType.Trim()</span>
                                        }
                                        @if (model.ContextLength is > 0)
                                        {
                                            <span class="model-row__context" title="Context length">@FormatContextK(model.ContextLength.Value)</span>
                                        }
                                        @if (model.SizeGb is > 0)
                                        {
                                            <span class="model-row__size">@model.SizeGb!.Value.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture) GB</span>
                                        }
                                    </span>
                                </button>
                            }
                        }
                    </section>

                    <!-- Footer summary -->
                    <footer class="models-footer" aria-label="Local model storage summary">
                        <span class="models-footer__summary">
                            You have <strong>@_state.VisibleCached.Count</strong> local model@(_state.VisibleCached.Count == 1 ? string.Empty : "s")@(CachedSizeLabel)
                        </span>
                        @if (!string.IsNullOrWhiteSpace(_modelCachePath))
                        {
                            <span class="models-footer__path" title="@_modelCachePath">@_modelCachePath</span>
                        }
                    </footer>
                </div>

                <!-- RIGHT: detail panel (collapsed by default; visible when a model is selected or pinned) -->
                @if (DetailPanelVisible)
                {
                    <aside class="models-detail-panel" aria-label="Model details">
                        <div class="models-detail-panel__toolbar">
                            <button type="button"
                                    class="icon-button @(_detailPinned ? "is-active" : string.Empty)"
                                    title="@(_detailPinned ? "Unpin detail panel" : "Pin detail panel always open")"
                                    aria-label="@(_detailPinned ? "Unpin detail panel" : "Pin detail panel always open")"
                                    aria-pressed="@_detailPinned.ToString().ToLowerInvariant()"
                                    @onclick="ToggleDetailPinAsync">
                                <!-- Pin / thumbtack icon — reinforces "keep panel open" intent -->
                                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M12 17v5"/><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V17a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z"/></svg>
                            </button>
                        </div>
                        @if (SelectedModel is { } selected)
                        {
                            <ModelCard Model="selected"
                                       IsCached="_state.IsCached(selected)"
                                       IsLoaded="_state.IsLoaded(selected)"
                                       Operation="_state.GetOperation(selected)"
                                       VariantSelection="_state.GetVariantSelection(selected)"
                                       FreeDiskGb="_freeDiskGb"
                                       OnMutationCompleted="RefreshCatalogAsync"
                                       OnDeleteRequested="OpenDeleteDialogAsync" />
                        }
                        else
                        {
                            <div class="models-detail-panel__empty">
                                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M5 6.5h14v11H5z" /><path d="M8 17.5V9h8" /><path d="M8 12.75h6.5" /></svg>
                                <p>Select a model to see details and manage it.</p>
                            </div>
                        }
                    </aside>
                }
            </div>
        }
    }

    <ConfirmDialog IsOpen="@(_deleteTarget is not null)"
                   Eyebrow="Delete cached model"
                   Title="Delete cached model?"
                   Message="@DeleteMessage"
                   ConfirmText="Delete cached model"
                   BusyText="Deleting…"
                   IsBusy="@_deleteBusy"
                   ErrorMessage="@_deleteError"
                   OnConfirm="ConfirmDeleteAsync"
                   OnCancel="CloseDeleteDialogAsync" />
</div>

@code {
    private readonly CatalogViewState _state = new();
    private ModelInfo? _deleteTarget;
    private bool _deleteBusy;
    private string? _deleteError;
    private double? _freeDiskGb;
    private string? _selectedAlias;
    private string? _modelCachePath;
    private bool _filtersOpen;
    private bool _detailPinned;
    private bool _pinStateLoaded;

    private bool DetailPanelVisible => _detailPinned || SelectedModel != null;

    private bool IsBusy => _state.Status == CatalogViewState.CatalogStatus.Loading;

    private int ActiveFilterCount
    {
        get
        {
            var count = 0;
            if (_state.Filter.Device is not null) count++;
            if (!string.IsNullOrWhiteSpace(_state.Filter.Task)) count++;
            if (!string.IsNullOrWhiteSpace(_state.Filter.Provider)) count++;
            if (_state.Filter.CachedOnly) count++;
            if (_state.ViewMode == CatalogViewState.CatalogViewMode.Full) count++;
            return count;
        }
    }

    private string DeviceFilterValue => _state.Filter.Device?.ToString() ?? string.Empty;

    private string LoadedSummary => _state.LoadedAliases.Count == 0
        ? "Loaded: none"
        : $"Loaded: {string.Join(", ", _state.LoadedAliases.Order(StringComparer.OrdinalIgnoreCase))}";

    private string DeleteMessage => _deleteTarget is null
        ? string.Empty
        : $"Delete cached model '{_deleteTarget.Alias}'? This frees {FormatSize(_deleteTarget.SizeGb)} and cannot be undone.";

    private ModelInfo? SelectedModel =>
        _selectedAlias is not null
            ? _state.Visible.FirstOrDefault(m => string.Equals(m.Alias, _selectedAlias, StringComparison.OrdinalIgnoreCase))
            : _state.Visible.Count > 0 ? _state.Visible[0] : null;

    private bool IsSelected(ModelInfo model) =>
        string.Equals(model.Alias, SelectedModel?.Alias, StringComparison.OrdinalIgnoreCase);

    private string CachedSizeLabel
    {
        get
        {
            var knownSizes = _state.VisibleCached
                .Where(m => m.SizeGb is > 0)
                .Select(m => m.SizeGb!.Value)
                .ToList();

            if (knownSizes.Count == 0)
            {
                return _state.VisibleCached.Count > 0 ? ", size unknown" : string.Empty;
            }

            var total = knownSizes.Sum();
            var suffix = knownSizes.Count < _state.VisibleCached.Count ? "+" : string.Empty;
            return $", taking up {total.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)}{suffix} GB";
        }
    }

    private static string RowDisplayName(ModelInfo model) =>
        string.IsNullOrWhiteSpace(model.DisplayName) ? model.Alias : model.DisplayName;

    protected override async Task OnInitializedAsync()
    {
        // Stateful landing: on first app visit to "/", redirect to Serve if models are cached.
        // Subsequent navigations to "/" (user-explicit) are not redirected.
        if (StartupNav.ShouldCheckStartupRedirect())
        {
            try
            {
                var cached = await CatalogService.ListCachedAsync();
                if (cached.Count > 0)
                {
                    Navigation.NavigateTo("/server");
                    return;
                }
            }
            catch
            {
                // If the catalog fails here, fall through to normal Discover load.
            }
        }

        await RefreshCatalogAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_pinStateLoaded)
        {
            _pinStateLoaded = true;
            try
            {
                var pinned = await JS.InvokeAsync<string?>("eval", "window.localStorage.getItem('fs-detail-pinned')");
                _detailPinned = pinned == "1";
                StateHasChanged();
            }
            catch
            {
                // localStorage unavailable (e.g. test environment) — keep default false
            }
        }
    }

    private void ToggleFilters()
    {
        _filtersOpen = !_filtersOpen;
    }

    private async Task ToggleDetailPinAsync()
    {
        _detailPinned = !_detailPinned;
        try
        {
            await JS.InvokeVoidAsync("eval", $"window.localStorage.setItem('fs-detail-pinned', '{(_detailPinned ? "1" : "0")}')");
        }
        catch
        {
            // localStorage unavailable — state is still toggled in memory
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshCatalogAsync()
    {
        _state.SetLoading();
        await InvokeAsync(StateHasChanged);

        try
        {
            var browseTask = CatalogService.BrowseAsync();
            var cachedTask = CatalogService.ListCachedAsync();
            var loadedTask = CatalogService.ListLoadedAsync();
            var settingsTask = SettingsService.GetAsync();

            await Task.WhenAll(browseTask, cachedTask, loadedTask, settingsTask);

            _state.AllModels = await browseTask;
            _state.SetAuthoritativeState(await cachedTask, await loadedTask);
            var settings = await settingsTask;
            _freeDiskGb = CatalogDiskSpace.GetFreeDiskGb(settings.ModelCacheDirectory);
            _modelCachePath = settings.ModelCacheDirectory;
            _state.Recompute();
        }
        catch (Exception ex)
        {
            _state.SetError($"Foundry Local catalog could not be loaded: {ex.Message}");
        }

        await InvokeAsync(StateHasChanged);
    }

    private Task ResetCatalogAsync()
    {
        _state.ResetToCuratedDefault();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnSearchChangedAsync(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        _state.Filter = _state.Filter with { SearchText = value };
        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnDeviceChangedAsync(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        var device = Enum.TryParse<Device>(value, ignoreCase: true, out var parsed) ? parsed : (Device?)null;
        _state.Filter = _state.Filter with { Device = device };
        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnTaskChangedAsync(ChangeEventArgs args)
    {
        _state.Filter = _state.Filter with { Task = NormalizeOptional(args.Value?.ToString()) };
        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnProviderChangedAsync(ChangeEventArgs args)
    {
        _state.Filter = _state.Filter with { Provider = NormalizeOptional(args.Value?.ToString()) };
        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnCachedOnlyChangedAsync(ChangeEventArgs args)
    {
        _state.Filter = _state.Filter with { CachedOnly = args.Value is true };
        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnViewModeChangedAsync(ChangeEventArgs args)
    {
        if (Enum.TryParse<CatalogViewState.CatalogViewMode>(args.Value?.ToString(), ignoreCase: true, out var mode))
        {
            _state.ViewMode = mode;
            _state.Recompute();
        }

        return InvokeAsync(StateHasChanged);
    }

    private static string? NormalizeOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value;
    }

    private Task SelectModelAsync(ModelInfo model)
    {
        _selectedAlias = model.Alias;
        return InvokeAsync(StateHasChanged);
    }

    private Task OpenDeleteDialogAsync(ModelInfo model)
    {
        _deleteTarget = model;
        _deleteError = null;
        _deleteBusy = false;
        return InvokeAsync(StateHasChanged);
    }

    private Task CloseDeleteDialogAsync()
    {
        _deleteTarget = null;
        _deleteError = null;
        _deleteBusy = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null)
        {
            return;
        }

        var target = _deleteTarget;
        _deleteBusy = true;
        _deleteError = null;
        var operation = _state.GetOperation(target);
        operation.Reset();
        operation.Phase = ModelOpPhase.Deleting;
        await InvokeAsync(StateHasChanged);

        try
        {
            await CatalogService.DeleteFromCacheAsync(target.Alias, userConfirmed: true);
            operation.Reset();
            _deleteTarget = null;
            await RefreshCatalogAsync();
        }
        catch (ModelBusyException ex)
        {
            operation.Fail(ex.Message, busy: true);
            _deleteError = ex.Message;
        }
        catch (Exception ex)
        {
            operation.Fail($"Delete failed: {ex.Message}");
            _deleteError = $"Delete failed: {ex.Message}";
        }
        finally
        {
            _deleteBusy = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private static string? RowHoverTitle(ModelInfo model)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(model.License))
        {
            parts.Add($"License: {model.License.Trim()}");
        }

        var variantCount = model.Variants?.Count ?? 0;
        parts.Add(variantCount == 0 ? "Variants: none reported" : $"Variants: {variantCount}");

        return parts.Count > 0 ? string.Join(" · ", parts) : null;
    }

    private static string FormatContextK(int contextLength)
    {
        if (contextLength >= 1000)
        {
            var k = contextLength / 1000.0;
            var label = k == Math.Floor(k) ? $"{(int)k}K" : $"{k.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)}K";
            return $"{label} ctx";
        }

        return $"{contextLength} ctx";
    }

    private static string FormatSize(double? sizeGb) =>
        sizeGb is null or <= 0 ? "an unknown amount of disk space" : $"{sizeGb.Value.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)} GB";
}
