@page "/"
@inject IFoundryCatalogService CatalogService
@inject ISettingsService SettingsService
@inject LocalContextReader ContextReader
@inject NavigationManager Navigation
@inject StartupNavigationService StartupNav

<div class="catalog-shell" data-testid="catalog-page">
    <div class="catalog-main">
    <PageHeader TitleId="catalog-title"
                Eyebrow=""
                Title="Browse models"
                Subtitle="Find and download ONNX models for this Mac." />

    @if (_state.Status == CatalogViewState.CatalogStatus.Loading)
    {
        <section class="catalog-state card" data-testid="catalog-loading" role="status" aria-live="polite" aria-label="Loading catalog">
            <h2>Loading catalog…</h2>
            <p class="status">Reading the Foundry Local catalog through the app service.</p>
        </section>
    }
    else if (_state.Status == CatalogViewState.CatalogStatus.Error)
    {
        <section class="catalog-state card catalog-state--error" data-testid="catalog-error" role="alert" aria-label="Catalog load failed">
            <h2>Catalog could not be loaded</h2>
            <p>@_state.ErrorMessage</p>
            <button id="catalog-retry" type="button" class="button" @onclick="RefreshCatalogAsync">Retry</button>
        </section>
    }
    else
    {
        <!-- Toolbar: search (always visible) + collapsible filter drawer -->
        <section class="catalog-controls card" aria-label="Catalog search, filters, and view controls">
            <!-- One search field: accepts literal tokens (alias / name / id) and
                 natural language. Filters literally as you type; Enter or the submit
                 arrow interprets the phrase into editable filter chips below. -->
            <div class="catalog-search-row" role="search" aria-label="Search or describe what you need">
                <div class="catalog-search-field">
                    <svg class="catalog-search-field__icon" viewBox="0 0 24 24" focusable="false" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="M21 21l-4.3-4.3" /></svg>
                    <label for="catalog-search" class="visually-hidden">Search or describe what you need</label>
                    <input id="catalog-search"
                           type="search"
                           class="catalog-search-field__input"
                           data-testid="discover-nl-input"
                           value="@_state.NlInputText"
                           @oninput="OnSearchInputAsync"
                           @onkeydown="OnSearchKeyDownAsync"
                           placeholder="Search or describe what you need…"
                           autocomplete="off"
                           spellcheck="false"
                           aria-label="Search or describe what you need"
                           aria-describedby="catalog-nl-hint" />
                    <button type="button"
                            class="catalog-search-field__submit"
                            data-testid="discover-nl-submit"
                            title="Interpret as filters"
                            aria-label="Interpret as filters"
                            disabled="@(string.IsNullOrWhiteSpace(_state.NlInputText))"
                            @onclick="ApplyNlQueryAsync">
                        <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                    </button>
                </div>
                <button type="button"
                        class="catalog-filters-toggle icon-button @(_filtersOpen ? "is-active" : string.Empty)"
                        aria-expanded="@_filtersOpen.ToString().ToLowerInvariant()"
                        aria-controls="catalog-filters-drawer"
                        title="@(_filtersOpen ? "Hide filters" : "Show filters")"
                        @onclick="ToggleFilters">
                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M4 6h16M7 12h10M10 18h4" /></svg>
                    @if (ActiveFilterCount > 0)
                    {
                        <span class="filter-active-count" aria-label="@ActiveFilterCount active filter@(ActiveFilterCount == 1 ? "" : "s")">@ActiveFilterCount</span>
                    }
                </button>
            </div>

            @if (_state.NlResult is { IsEmpty: false })
            {
                <div class="catalog-nl-chips" data-testid="discover-nl-chips" role="group" aria-label="Interpreted filters">
                    <span id="catalog-nl-hint" class="catalog-nl-interpreted-label">Interpreted as</span>
                    @foreach (var chip in _state.NlResult.Chips)
                    {
                        <button type="button"
                                class="catalog-nl-chip"
                                title="Remove @chip.Label"
                                aria-label="Remove filter: @chip.Label"
                                @onclick="() => RemoveNlChipAsync(chip)">
                            @chip.Label
                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12" /></svg>
                        </button>
                    }
                    <button type="button"
                            class="catalog-nl-clear"
                            aria-label="Clear all inferred filters"
                            @onclick="ClearNlAsync">Clear all</button>
                </div>
            }

            @if (_filtersOpen)
            {
                <div id="catalog-filters-drawer" class="catalog-filters-drawer" role="group" aria-label="Filters">
                    <div class="field">
                        <label for="filter-device">Device</label>
                        <select id="filter-device" value="@DeviceFilterValue" @onchange="OnDeviceChangedAsync">
                            <option value="">All devices</option>
                            @foreach (var device in _state.Facets.Devices)
                            {
                                <option value="@device">@device.ToString().ToUpperInvariant()</option>
                            }
                        </select>
                    </div>

                    <div class="field">
                        <label for="filter-task">Task</label>
                        <select id="filter-task" value="@(_state.Filter.Task ?? string.Empty)" @onchange="OnTaskChangedAsync">
                            <option value="">All tasks</option>
                            @foreach (var task in _state.Facets.Tasks)
                            {
                                <option value="@task">@task</option>
                            }
                        </select>
                    </div>

                    <div class="field">
                        <label for="filter-provider">Provider</label>
                        <select id="filter-provider" value="@(_state.Filter.Provider ?? string.Empty)" @onchange="OnProviderChangedAsync">
                            <option value="">All providers</option>
                            @foreach (var provider in _state.Facets.Providers)
                            {
                                <option value="@provider">@provider</option>
                            }
                        </select>
                    </div>

                    <div class="field field-checkbox">
                        <input id="filter-cached"
                               type="checkbox"
                               checked="@_state.Filter.CachedOnly"
                               @onchange="OnCachedOnlyChangedAsync" />
                        <label for="filter-cached">Cached only</label>
                    </div>

                    <div class="field">
                        <label for="view-toggle">Catalog view</label>
                        <select id="view-toggle" value="@_state.ViewMode" @onchange="OnViewModeChangedAsync">
                            <option value="@CatalogViewState.CatalogViewMode.Curated">Curated</option>
                            <option value="@CatalogViewState.CatalogViewMode.Full">Full catalog</option>
                        </select>
                    </div>
                </div>
            }
        </section>

        @if (_state.Status != CatalogViewState.CatalogStatus.Loading
             && _state.Status != CatalogViewState.CatalogStatus.Error)
        {
            <div class="catalog-result-line" aria-label="Result summary">
                <span class="catalog-count-chip" data-testid="catalog-count">
                    <strong>@_state.Visible.Count.ToString("N0")</strong> of @_state.AllModels.Count.ToString("N0")
                </span>
                <span class="catalog-sort-label"
                      data-testid="@(_state.IsShowingCurated ? "curated-banner" : null)"
                      title="@(_state.IsShowingCurated ? "Curated by FoundryStudio for fit on Apple Silicon — not a quality ranking." : "Installed models are listed first.")">
                    @(_state.IsShowingCurated ? "Sorted by fit · installed first" : "Installed first")
                </span>
                <span class="visually-hidden" data-testid="loaded-indicator" aria-live="polite">@LoadedSummary</span>

                <div class="catalog-legend" aria-label="Capability legend">
                    <span class="catalog-legend__item cap-mark--vision"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6z" /><circle cx="12" cy="12" r="2.5" /></svg>Vision</span>
                    <span class="catalog-legend__item cap-mark--tools"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L4 17v3h3l5.3-5.3a4 4 0 0 0 5.4-5.4l-2.6 2.6-3-3z" /></svg>Tools</span>
                    <span class="catalog-legend__item cap-mark--reasoning"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" /><path d="M12 3a9 9 0 0 1 0 18z" fill="currentColor" stroke="none" /></svg>Reasoning</span>
                </div>

                <button id="catalog-refresh"
                        data-testid="refresh-catalog"
                        type="button"
                        class="icon-button catalog-refresh"
                        aria-label="Refresh catalog"
                        title="Refresh catalog"
                        @onclick="RefreshCatalogAsync"
                        disabled="@IsBusy">
                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M20 11a8 8 0 1 0-.5 4" /><path d="M20 5v6h-6" /></svg>
                </button>
            </div>

            @if (_state.PersonalizationActive && !_state.PersonalizationProfile.IsEmpty)
            {
                <div class="personalized-banner" data-testid="discover-personalized-banner" role="status" aria-live="polite">
                    <span class="personalized-banner__label">
                        Personalized for: <strong>@_state.PersonalizationProfile.SummaryLabel()</strong>
                    </span>
                    <span class="personalized-banner__actions">
                        <button type="button"
                                class="personalized-banner__link"
                                title="Models matching your local .copilot context appear first. No data is uploaded."
                                @onclick="ShowPersonalizationInfoAsync">
                            how this works
                        </button>
                        <span aria-hidden="true">·</span>
                        <button type="button"
                                class="personalized-banner__link"
                                @onclick="TurnOffPersonalizationAsync">
                            turn off
                        </button>
                    </span>
                </div>
            }
            else if (_state.PersonalizationActive && _state.PersonalizationProfile.IsEmpty)
            {
                <p class="personalized-banner personalized-banner--empty"
                   data-testid="discover-personalized-banner"
                   role="status">
                    Personalized recommendations enabled — no local context found in ~/.copilot
                </p>
            }
        }

        @if (_state.Status == CatalogViewState.CatalogStatus.Empty)
        {
            <section class="catalog-state card" data-testid="catalog-empty" role="status" aria-live="polite" aria-label="No matching catalog models">
                <span class="foundry-mark catalog-empty__mark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false"><path d="M5 6.5h14v11H5z" /><path d="M8 17.5V9h8" /><path d="M8 12.75h6.5" /></svg>
                </span>
                <h2>Choose your first model</h2>
                <p class="status">Try a different search, broaden the facets, or reset to the curated default.</p>
                <button id="catalog-reset" type="button" class="button" @onclick="ResetCatalogAsync">Reset filters</button>
            </section>
        }
        else
        {
            <!-- Merged, installed-first card grid. Cards never expand; selecting one populates the
                 detail sidebar. Clicking empty grid space clears the selection (hides the sidebar). -->
            <div class="models-grid-scroll" @onclick="ClearSelection">
                <div class="models-grid" role="list" aria-label="Models" data-testid="models-list">
                    @foreach (var model in MergedModels)
                    {
                        <ModelGridCard Model="model"
                                       IsCached="_state.IsCached(model)"
                                       IsLoaded="_state.IsLoaded(model)"
                                       IsSelected="IsSelected(model)"
                                       Operation="_state.GetOperation(model)"
                                       VariantSelection="_state.GetVariantSelection(model)"
                                       OnSelect="SelectModelAsync"
                                       OnMutationCompleted="RefreshCatalogAsync" />
                    }
                </div>

                <footer class="models-footer" aria-label="Local model storage summary">
                    <span class="models-footer__summary">
                        You have <strong>@_state.VisibleCached.Count</strong> local model@(_state.VisibleCached.Count == 1 ? string.Empty : "s")@(CachedSizeLabel)
                    </span>
                    @if (!string.IsNullOrWhiteSpace(_modelCachePath))
                    {
                        <span class="models-footer__path" title="@_modelCachePath">@_modelCachePath</span>
                    }
                </footer>
            </div>
        }
    }
    </div>

    @if (_state.Status != CatalogViewState.CatalogStatus.Loading
         && _state.Status != CatalogViewState.CatalogStatus.Error
         && SelectedModel is { } selected)
    {
        <DetailSidebar Model="selected"
                       IsCached="_state.IsCached(selected)"
                       IsLoaded="_state.IsLoaded(selected)"
                       Operation="_state.GetOperation(selected)"
                       VariantSelection="_state.GetVariantSelection(selected)"
                       FreeDiskGb="_freeDiskGb"
                       OnMutationCompleted="RefreshCatalogAsync"
                       OnDeleteRequested="OpenDeleteDialogAsync" />
    }

    <ConfirmDialog IsOpen="@(_deleteTarget is not null)"
                   Eyebrow="Delete cached model"
                   Title="Delete cached model?"
                   Message="@DeleteMessage"
                   ConfirmText="Delete cached model"
                   BusyText="Deleting…"
                   IsBusy="@_deleteBusy"
                   ErrorMessage="@_deleteError"
                   OnConfirm="ConfirmDeleteAsync"
                   OnCancel="CloseDeleteDialogAsync" />
</div>

@code {
    private readonly CatalogViewState _state = new();
    private readonly NaturalLanguageQueryInterpreter _nlInterpreter = new();
    private ModelInfo? _deleteTarget;
    private bool _deleteBusy;
    private string? _deleteError;
    private double? _freeDiskGb;
    private string? _selectedAlias;
    private string? _modelCachePath;
    private bool _filtersOpen;
    private bool _showPersonalizationInfo;

    private bool IsBusy => _state.Status == CatalogViewState.CatalogStatus.Loading;

    private int ActiveFilterCount
    {
        get
        {
            var count = 0;
            if (_state.Filter.Device is not null) count++;
            if (!string.IsNullOrWhiteSpace(_state.Filter.Task)) count++;
            if (!string.IsNullOrWhiteSpace(_state.Filter.Provider)) count++;
            if (_state.Filter.CachedOnly) count++;
            if (_state.ViewMode == CatalogViewState.CatalogViewMode.Full) count++;
            return count;
        }
    }

    private string DeviceFilterValue => _state.Filter.Device?.ToString() ?? string.Empty;

    private string LoadedSummary => _state.LoadedAliases.Count == 0
        ? "Loaded: none"
        : $"Loaded: {string.Join(", ", _state.LoadedAliases.Order(StringComparer.OrdinalIgnoreCase))}";

    private string DeleteMessage => _deleteTarget is null
        ? string.Empty
        : $"Delete cached model '{_deleteTarget.Alias}'? This frees {FormatSize(_deleteTarget.SizeGb)} and cannot be undone.";

    // No auto-selection: null until the user clicks a card (so the detail sidebar is hidden by default).
    private ModelInfo? SelectedModel =>
        _selectedAlias is not null
            ? _state.Visible.FirstOrDefault(m => string.Equals(m.Alias, _selectedAlias, StringComparison.OrdinalIgnoreCase))
            : null;

    private bool IsSelected(ModelInfo model) =>
        _selectedAlias is not null
        && string.Equals(model.Alias, _selectedAlias, StringComparison.OrdinalIgnoreCase);

    // Merged, installed-first ordering for the card grid (VisibleCached then VisibleAvailable are already
    // partitioned from Visible; concatenating keeps installed models first within the single grid).
    private IReadOnlyList<ModelInfo> MergedModels
    {
        get
        {
            var merged = new List<ModelInfo>(_state.VisibleCached.Count + _state.VisibleAvailable.Count);
            merged.AddRange(_state.VisibleCached);
            merged.AddRange(_state.VisibleAvailable);
            return merged;
        }
    }

    private string CachedSizeLabel
    {
        get
        {
            var knownSizes = _state.VisibleCached
                .Where(m => m.SizeGb is > 0)
                .Select(m => m.SizeGb!.Value)
                .ToList();

            if (knownSizes.Count == 0)
            {
                return _state.VisibleCached.Count > 0 ? ", size unknown" : string.Empty;
            }

            var total = knownSizes.Sum();
            var suffix = knownSizes.Count < _state.VisibleCached.Count ? "+" : string.Empty;
            return $", taking up {total.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)}{suffix} GB";
        }
    }

    private static string RowDisplayName(ModelInfo model) =>
        string.IsNullOrWhiteSpace(model.DisplayName) ? model.Alias : model.DisplayName;

    protected override async Task OnInitializedAsync()
    {
        // Stateful landing: on first app visit to "/", redirect to Serve if models are cached.
        // Subsequent navigations to "/" (user-explicit) are not redirected.
        if (StartupNav.ShouldCheckStartupRedirect())
        {
            try
            {
                var cached = await CatalogService.ListCachedAsync();
                if (cached.Count > 0)
                {
                    Navigation.NavigateTo("/server");
                    return;
                }
            }
            catch
            {
                // If the catalog fails here, fall through to normal Discover load.
            }
        }

        await RefreshCatalogAsync();
    }

    private void ToggleFilters()
    {
        _filtersOpen = !_filtersOpen;
    }

    private async Task RefreshCatalogAsync()
    {
        _state.SetLoading();
        await InvokeAsync(StateHasChanged);

        try
        {
            var browseTask = CatalogService.BrowseAsync();
            var cachedTask = CatalogService.ListCachedAsync();
            var loadedTask = CatalogService.ListLoadedAsync();
            var settingsTask = SettingsService.GetAsync();

            await Task.WhenAll(browseTask, cachedTask, loadedTask, settingsTask);

            _state.AllModels = await browseTask;
            _state.SetAuthoritativeState(await cachedTask, await loadedTask);
            var settings = await settingsTask;
            _freeDiskGb = CatalogDiskSpace.GetFreeDiskGb(settings.ModelCacheDirectory);
            _modelCachePath = settings.ModelCacheDirectory;

            // Personalization: read on-device context only when the user has opted in.
            _state.PersonalizationActive = settings.PersonalizedRecommendations;
            if (settings.PersonalizedRecommendations)
            {
                await ApplyPersonalizationAsync();
            }
            else
            {
                _state.PersonalizationProfile = FoundryStudio.Core.Personalization.ContextProfile.Empty;
            }

            _state.Recompute();
        }
        catch (Exception ex)
        {
            _state.SetError($"Foundry Local catalog could not be loaded: {ex.Message}");
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ApplyPersonalizationAsync()
    {
        try
        {
            var contextData = await ContextReader.ReadAsync();
            _state.PersonalizationProfile = FoundryStudio.Core.Personalization.LocalContextProfiler.Derive(
                contextData.InstructionsContent,
                contextData.Skills);
        }
        catch
        {
            // On-device read failed — treat as empty; never crash the catalog.
            _state.PersonalizationProfile = FoundryStudio.Core.Personalization.ContextProfile.Empty;
        }
    }

    private async Task TurnOffPersonalizationAsync()
    {
        try
        {
            var settings = await SettingsService.GetAsync();
            await SettingsService.UpdateAsync(settings with { PersonalizedRecommendations = false });
        }
        catch
        {
            // Best-effort; proceed anyway.
        }

        _state.PersonalizationActive = false;
        _state.PersonalizationProfile = FoundryStudio.Core.Personalization.ContextProfile.Empty;
        _state.Recompute();
        await InvokeAsync(StateHasChanged);
    }

    private Task ShowPersonalizationInfoAsync()
    {
        _showPersonalizationInfo = !_showPersonalizationInfo;
        return InvokeAsync(StateHasChanged);
    }

    private Task ResetCatalogAsync()
    {
        _state.ResetToCuratedDefault();
        return InvokeAsync(StateHasChanged);
    }

    // ── Search handlers (one field: literal filter + NL interpret) ──────────────

    // Live literal filtering as the user types, so known-item search (alias/name/id)
    // is instant. Pressing Enter or the submit arrow runs NL interpretation, which
    // turns the phrase into editable filter chips.
    private Task OnSearchInputAsync(ChangeEventArgs args)
    {
        var value = args.Value?.ToString() ?? string.Empty;
        _state.NlInputText = value;

        if (string.IsNullOrWhiteSpace(value))
        {
            // Clearing the field clears any interpreted chips and their filters.
            _state.NlResult = null;
            _state.NlSortHint = NlSortHint.None;
            _state.Filter = _state.Filter with { SearchText = null };
        }
        else
        {
            _state.Filter = _state.Filter with { SearchText = value };
        }

        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnSearchKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            return ApplyNlQueryAsync();
        }

        return Task.CompletedTask;
    }

    private Task ApplyNlQueryAsync()
    {
        if (string.IsNullOrWhiteSpace(_state.NlInputText))
        {
            return Task.CompletedTask;
        }

        var result = _nlInterpreter.Interpret(
            _state.NlInputText,
            _state.Facets.Tasks,
            _state.Facets.Providers);

        if (result.IsEmpty)
        {
            // Nothing interpretable — put the whole input into SearchText so it still filters
            _state.NlResult = null;
            _state.NlSortHint = NlSortHint.None;
            _state.Filter = _state.Filter with { SearchText = _state.NlInputText.Trim() };
        }
        else
        {
            _state.NlResult = result;
            _state.NlSortHint = result.SortHint;
            // Merge NL filter on top of existing filter (NL wins for fields it set).
            _state.Filter = new CatalogFilter(
                Device: result.Filter.Device ?? _state.Filter.Device,
                Task: result.Filter.Task ?? _state.Filter.Task,
                Provider: result.Filter.Provider ?? _state.Filter.Provider,
                SearchText: result.Filter.SearchText,
                CachedOnly: _state.Filter.CachedOnly);
            _state.ViewMode = CatalogViewState.CatalogViewMode.Full;
        }

        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task RemoveNlChipAsync(NlInferredChip chip)
    {
        if (_state.NlResult is null)
        {
            return Task.CompletedTask;
        }

        // Clear the filter field corresponding to this chip kind
        _state.Filter = chip.Kind switch
        {
            NlChipKind.Device => _state.Filter with { Device = null },
            NlChipKind.Task => _state.Filter with { Task = null },
            NlChipKind.Provider => _state.Filter with { Provider = null },
            NlChipKind.SearchText => _state.Filter with { SearchText = null },
            NlChipKind.SortHint => _state.Filter, // sort is separate; cleared below
            NlChipKind.Capability => _state.Filter, // capability hints are display-only
            _ => _state.Filter,
        };

        if (chip.Kind == NlChipKind.SortHint)
        {
            _state.NlSortHint = NlSortHint.None;
        }

        // Rebuild chips without the removed one
        var remainingChips = _state.NlResult.Chips
            .Where(c => c != chip)
            .ToList();

        _state.NlResult = remainingChips.Count > 0
            ? _state.NlResult with { Chips = remainingChips }
            : null;

        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task ClearNlAsync()
    {
        _state.NlInputText = string.Empty;
        _state.NlResult = null;
        _state.NlSortHint = NlSortHint.None;
        // Clear only the NL-contributed fields; leave power-filter drawer state
        _state.Filter = new CatalogFilter(
            CachedOnly: _state.Filter.CachedOnly);
        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnDeviceChangedAsync(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        var device = Enum.TryParse<Device>(value, ignoreCase: true, out var parsed) ? parsed : (Device?)null;
        _state.Filter = _state.Filter with { Device = device };
        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnTaskChangedAsync(ChangeEventArgs args)
    {
        _state.Filter = _state.Filter with { Task = NormalizeOptional(args.Value?.ToString()) };
        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnProviderChangedAsync(ChangeEventArgs args)
    {
        _state.Filter = _state.Filter with { Provider = NormalizeOptional(args.Value?.ToString()) };
        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnCachedOnlyChangedAsync(ChangeEventArgs args)
    {
        _state.Filter = _state.Filter with { CachedOnly = args.Value is true };
        _state.Recompute();
        return InvokeAsync(StateHasChanged);
    }

    private Task OnViewModeChangedAsync(ChangeEventArgs args)
    {
        if (Enum.TryParse<CatalogViewState.CatalogViewMode>(args.Value?.ToString(), ignoreCase: true, out var mode))
        {
            _state.ViewMode = mode;
            _state.Recompute();
        }

        return InvokeAsync(StateHasChanged);
    }

    private static string? NormalizeOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value;
    }

    private Task SelectModelAsync(ModelInfo model)
    {
        // Toggle off if the same card is clicked again; otherwise select it.
        _selectedAlias = string.Equals(_selectedAlias, model.Alias, StringComparison.OrdinalIgnoreCase)
            ? null
            : model.Alias;
        return InvokeAsync(StateHasChanged);
    }

    private Task ClearSelection()
    {
        if (_selectedAlias is null)
        {
            return Task.CompletedTask;
        }

        _selectedAlias = null;
        return InvokeAsync(StateHasChanged);
    }

    private Task OpenDeleteDialogAsync(ModelInfo model)
    {
        _deleteTarget = model;
        _deleteError = null;
        _deleteBusy = false;
        return InvokeAsync(StateHasChanged);
    }

    private Task CloseDeleteDialogAsync()
    {
        _deleteTarget = null;
        _deleteError = null;
        _deleteBusy = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null)
        {
            return;
        }

        var target = _deleteTarget;
        _deleteBusy = true;
        _deleteError = null;
        var operation = _state.GetOperation(target);
        operation.Reset();
        operation.Phase = ModelOpPhase.Deleting;
        await InvokeAsync(StateHasChanged);

        try
        {
            await CatalogService.DeleteFromCacheAsync(target.Alias, userConfirmed: true);
            operation.Reset();
            _deleteTarget = null;
            await RefreshCatalogAsync();
        }
        catch (ModelBusyException ex)
        {
            operation.Fail(ex.Message, busy: true);
            _deleteError = ex.Message;
        }
        catch (Exception ex)
        {
            operation.Fail($"Delete failed: {ex.Message}");
            _deleteError = $"Delete failed: {ex.Message}";
        }
        finally
        {
            _deleteBusy = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private static string? RowHoverTitle(ModelInfo model)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(model.License))
        {
            parts.Add($"License: {model.License.Trim()}");
        }

        var variantCount = model.Variants?.Count ?? 0;
        parts.Add(variantCount == 0 ? "Variants: none reported" : $"Variants: {variantCount}");

        return parts.Count > 0 ? string.Join(" · ", parts) : null;
    }

    private static string FormatContextK(int contextLength)
    {
        if (contextLength >= 1000)
        {
            var k = contextLength / 1000.0;
            var label = k == Math.Floor(k) ? $"{(int)k}K" : $"{k.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)}K";
            return $"{label} ctx";
        }

        return $"{contextLength} ctx";
    }

    private static string FormatSize(double? sizeGb) =>
        sizeGb is null or <= 0 ? "an unknown amount of disk space" : $"{sizeGb.Value.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)} GB";
}
