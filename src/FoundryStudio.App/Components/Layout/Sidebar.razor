@inject NavigationManager Navigation

<aside class="sidebar" aria-label="FoundryStudio navigation">
    <a class="sidebar__skip" href="#main-content">Skip to content</a>
    <nav class="sidebar-nav" aria-label="Primary">
        <div class="sidebar-nav__group" aria-labelledby="nav-group-workshop">
            <p id="nav-group-workshop" class="sidebar-nav__eyebrow">Workshop</p>
            <NavLink id="nav-models" data-testid="nav-models" class="sidebar-nav__row" href="/" Match="NavLinkMatch.All" aria-label="Models catalog">
                <span class="sidebar-nav__icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 7h16"/><path d="M6 7v12h12V7"/><path d="M9 11h6"/><path d="M9 15h4"/></svg></span>
                <span>Models</span>
            </NavLink>
            <NavLink id="nav-chat" data-testid="nav-chat" class="sidebar-nav__row" href="/chat" aria-label="Chat">
                <span class="sidebar-nav__icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 6.5h14v9H8l-3 3z"/><path d="M8 10h8"/><path d="M8 13h5"/></svg></span>
                <span>Chat</span>
            </NavLink>
            <NavLink id="nav-server" data-testid="nav-server" class="sidebar-nav__row" href="/server" aria-label="Server">
                <span class="sidebar-nav__icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 7h14v4H5z"/><path d="M5 13h14v4H5z"/><path d="M8 9h.01"/><path d="M8 15h.01"/></svg></span>
                <span>Server</span>
            </NavLink>
        </div>
    </nav>
</aside>
