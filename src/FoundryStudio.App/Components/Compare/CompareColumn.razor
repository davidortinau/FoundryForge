@using FoundryStudio.Core.Compare
@using FoundryStudio.Core.Chat
@using System.Globalization

<div class="compare-column" data-testid="compare-column">
    <!-- Fixed header: model name + live metrics (never reflows the prose below) -->
    <header class="compare-column-header" data-testid="compare-column-metrics">
        <div class="compare-column-header__name">
            <span class="compare-col-model-name" title="@ModelName">@ModelName</span>
            @if (State.IsStreaming)
            {
                <span class="pill chat-message__streaming" aria-live="polite">Generating…</span>
            }
            else if (State.IsDone && !State.IsError && !IsGarbled)
            {
                <span class="pill compare-col-done-pill">Done</span>
            }
        </div>
        @if (State.Metrics is { } m && !State.IsError)
        {
            <dl class="compare-metrics" aria-label="Metrics for @ModelName">
                @if (m.TimeToFirstToken is { } ttft)
                {
                    <div data-testid="cmp-metric-ttft">
                        <dt>TTFT</dt>
                        <dd>@FormatDuration(ttft)</dd>
                    </div>
                }
                @if (m.TokensPerSecond is { } tps)
                {
                    <div data-testid="cmp-metric-tps">
                        <dt>tok/s</dt>
                        <dd>@tps.ToString("0.0", CultureInfo.CurrentCulture)</dd>
                    </div>
                }
                @if (m.TotalTokens is { } total)
                {
                    <div data-testid="cmp-metric-total">
                        <dt>tokens</dt>
                        <dd>@total.ToString("N0", CultureInfo.CurrentCulture)</dd>
                    </div>
                }
            </dl>
        }
    </header>

    <!-- Scrollable response body (metrics stay fixed in header above) -->
    <div class="compare-column-body">
        @if (State.IsError)
        {
            <div class="compare-col-error" data-testid="compare-column-error" role="alert">
                <p class="compare-col-error__label">Response error</p>
                <p class="compare-col-error__msg">@(State.ErrorMessage ?? "This model returned an error.")</p>
            </div>
        }
        else if (State.IsDone && IsGarbled)
        {
            <!-- Reuse the honesty decode-failure pattern from MessageBubble -->
            <div class="compare-col-error" data-testid="compare-column-error" role="alert">
                <p class="compare-col-error__label">Unreadable response</p>
                <p class="compare-col-error__msg">The model returned a garbled or empty response. This is usually temporary — try again.</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(State.Text))
        {
            <div class="compare-col-text chat-markdown">@((MarkupString)ChatMarkdown.Render(State.Text).Html)</div>
        }
        else if (State.IsStreaming)
        {
            <p class="chat-awaiting" role="status" aria-live="polite">Waiting for the first token…</p>
        }
        else if (State.IsDone && !State.IsError)
        {
            <p class="compare-col-empty status">No content in response.</p>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public CompareColumnState State { get; set; } = null!;

    private string ModelName =>
        string.IsNullOrWhiteSpace(State.Model.DisplayName) ? State.Model.Alias : State.Model.DisplayName;

    /// <summary>
    /// Mirrors the garbled-output check from MessageBubble: empty or >60% bad chars.
    /// Only reported after streaming ends (IsDone) so partial output never flashes as an error.
    /// </summary>
    private bool IsGarbled
    {
        get
        {
            if (!State.IsDone) return false;
            var trimmed = State.Text.Trim();
            if (string.IsNullOrEmpty(trimmed)) return true;
            var nonSpace = trimmed.Count(c => c != ' ' && c != '\t' && c != '\n' && c != '\r');
            if (nonSpace == 0) return true;
            var badChars = trimmed.Count(c => c == '?' || c == '\uFFFD');
            return (double)badChars / nonSpace > 0.6;
        }
    }

    private static string FormatDuration(TimeSpan value) =>
        $"{value.TotalMilliseconds.ToString("0", CultureInfo.CurrentCulture)} ms";
}
