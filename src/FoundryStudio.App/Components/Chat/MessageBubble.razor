@using FoundryStudio.Core.Chat
@inject IJSRuntime Js

<article class="chat-message chat-message--@RoleCss"
         data-testid="@TestId"
         data-streaming="@StreamingValue"
         aria-live="@(IsAssistant ? "polite" : null)">
    <div class="chat-message__meta">
        <span class="chat-message__role">@RoleLabel</span>
        @if (IsStreaming)
        {
            <span class="pill chat-message__streaming">pouring response</span>
        }
    </div>
    @if (IsAssistant)
    {
        <div class="chat-markdown" data-testid="chat-markdown">@((MarkupString)Rendered.Html)</div>
        @if (Rendered.CodeBlocks.Count > 0)
        {
            <div class="chat-codeblocks" aria-label="Code blocks in assistant reply">
                @foreach (var block in EnumerateCodeBlocks())
                {
                    <figure class="chat-codeblock" data-testid="chat-codeblock">
                        <figcaption>
                            <span>@(string.IsNullOrWhiteSpace(block.Value.Language) ? "code" : block.Value.Language)</span>
                            <button type="button"
                                    class="button button-secondary chat-code-copy"
                                    data-testid="chat-code-copy"
                                    aria-label="Copy exact code block"
                                    @onclick="() => CopyCodeAsync(block.Value.Code)">
                                Copy code
                            </button>
                        </figcaption>
                        <pre><code>@block.Value.Code</code></pre>
                    </figure>
                }
            </div>
        }
    }
    else
    {
        <p>@Content</p>
    }
</article>

@code {
    [Parameter, EditorRequired] public ChatTurnRole Role { get; set; }

    [Parameter] public string Content { get; set; } = string.Empty;

    [Parameter] public bool IsStreaming { get; set; }

    private bool IsAssistant => Role == ChatTurnRole.Assistant;

    private string TestId => IsAssistant ? "chat-msg-assistant" : "chat-msg-user";

    private string? StreamingValue => IsAssistant ? (IsStreaming ? "true" : "false") : null;

    private string RoleCss => IsAssistant ? "assistant" : "user";

    private string RoleLabel => IsAssistant ? "Assistant" : "You";

    private RenderedMarkdown Rendered => IsAssistant ? ChatMarkdown.Render(Content) : new RenderedMarkdown(string.Empty, Array.Empty<CodeBlock>());

    private IEnumerable<KeyValuePair<int, CodeBlock>> EnumerateCodeBlocks() => Rendered.CodeBlocks.Select((value, index) => new KeyValuePair<int, CodeBlock>(index, value));

    private ValueTask CopyCodeAsync(string code) => Js.InvokeVoidAsync("foundryStudioClipboard.copy", code);
}
