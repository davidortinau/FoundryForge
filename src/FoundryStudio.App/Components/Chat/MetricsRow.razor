@using System.Globalization
@using FoundryStudio.Core.Models

@if (Metrics is not null && ShouldShow)
{
    <details class="chat-metrics-disclosure">
        <summary class="chat-metrics-summary">Run details</summary>
        <dl class="chat-metrics" data-testid="chat-metrics" aria-label="Generation metrics">
            @if (Metrics.TimeToFirstToken is not null)
            {
                <div data-testid="metric-ttft"><dt>TTFT</dt><dd>@FormatDuration(Metrics.TimeToFirstToken)</dd></div>
            }
            @if (Metrics.TokensPerSecond is not null)
            {
                <div data-testid="metric-tps"><dt>Tokens/sec</dt><dd>@FormatRate(Metrics.TokensPerSecond)</dd></div>
            }
            @if (Metrics.TotalTokens is not null)
            {
                <div data-testid="metric-total"><dt>Total tokens</dt><dd>@FormatTotal(Metrics.TotalTokens)</dd></div>
            }
            @if (Metrics.StopReason is not StopReason.Unknown)
            {
                <div data-testid="metric-stop"><dt>Stop</dt><dd>@FormatStop(Metrics.StopReason)</dd></div>
            }
        </dl>
    </details>
}

@code {
    [Parameter] public GenerationMetrics? Metrics { get; set; }

    /// <summary>Suppress metrics for failed, cancelled, or garbled responses.</summary>
    [Parameter] public bool ShouldShow { get; set; } = true;

    private static string FormatDuration(TimeSpan? value) =>
        value is null ? string.Empty : $"{value.Value.TotalMilliseconds.ToString("0", CultureInfo.CurrentCulture)} ms";

    private static string FormatRate(double? value) =>
        value is null ? string.Empty : value.Value.ToString("0.0", CultureInfo.CurrentCulture);

    private static string FormatTotal(int? value) =>
        value is null ? string.Empty : value.Value.ToString("N0", CultureInfo.CurrentCulture);

    private static string FormatStop(StopReason reason) => reason switch
    {
        StopReason.Natural => "natural",
        StopReason.MaxTokens => "max-tokens",
        StopReason.ToolCalls => "tool-calls",
        StopReason.UserCancelled => "cancelled",
        StopReason.Error => "error",
        _ => "unknown"
    };
}
