@*
  ServeModelList — shows the currently-tempered (loaded) models that are reachable at the endpoint.
  Only visible while the server is running. Unload is non-destructive (cache is preserved).
*@
@inject ServingStateService ServingState
@implements IDisposable

@if (ServingState.IsRunning)
{
    <section class="card serve-model-section"
             aria-labelledby="serve-model-section-title">
        <div class="serve-model-section__header">
            <p class="eyebrow">Reachable models</p>
            <h2 id="serve-model-section-title">Models at the endpoint right now</h2>
            <p class="serve-model-section__hint">
                These are the tempered (loaded) models a caller can address by <code>model</code> id.
            </p>
        </div>

        @if (ServingState.LoadedModels.Count == 0)
        {
            <p class="server-note server-note--info" role="note">
                Server is on, but no models are tempered yet — temper a model to make it reachable.
            </p>
        }
        else
        {
            <ul class="serve-model-list"
                data-testid="serve-model-list"
                aria-label="Tempered models reachable at the endpoint">
                @foreach (var model in ServingState.LoadedModels)
                {
                    <li class="serve-model-row @(_unloadingAlias == model.Alias ? "is-busy" : string.Empty)"
                        data-testid="serve-model-row">
                        <div class="serve-model-row__info">
                            <span class="cache-badge cache-badge--loaded" aria-label="Tempered">
                                <svg aria-hidden="true" viewBox="0 0 24 24">
                                    <circle cx="12" cy="12" r="7" />
                                    <path d="M12 8v4l2.5 2.5" />
                                </svg>
                                Tempered
                            </span>
                            <span class="serve-model-row__name">@model.DisplayName</span>
                        </div>
                        <div class="serve-model-row__id-cell">
                            <span class="serve-model-row__id-label">Model id</span>
                            <code class="serve-model-row__id"
                                  data-testid="serve-model-id"
                                  title="Exact model id to put in the API 'model' field">@model.Id</code>
                        </div>
                        <div class="serve-model-row__actions">
                            <button type="button"
                                    class="button button-ghost"
                                    data-testid="serve-model-unload"
                                    aria-label="Unload @model.DisplayName from memory (cache is preserved)"
                                    disabled="@(_unloadingAlias is not null)"
                                    @onclick="() => UnloadAsync(model.Alias)">
                                @(_unloadingAlias == model.Alias ? "Unloading…" : "Unload")
                            </button>
                        </div>
                    </li>
                }
            </ul>
        }
    </section>
}

@code {
    private string? _unloadingAlias;

    protected override void OnInitialized()
    {
        ServingState.OnChanged += HandleChanged;
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    private async Task UnloadAsync(string alias)
    {
        if (_unloadingAlias is not null) return;

        _unloadingAlias = alias;
        await InvokeAsync(StateHasChanged);
        await ServingState.UnloadModelAsync(alias);
        _unloadingAlias = null;
        // ServingState.OnChanged fires from within UnloadModelAsync, re-rendering the list.
    }

    public void Dispose()
    {
        ServingState.OnChanged -= HandleChanged;
    }
}
