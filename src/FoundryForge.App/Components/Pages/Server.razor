@page "/server"
@using System.Globalization
@using FoundryForge.App.Components.Server
@inject ServingStateService ServingState
@inject IJSRuntime Js
@implements IDisposable

<div class="server-shell" data-testid="server-page">

    @* ── 1. Header ────────────────────────────────────────────────────────────────────────── *@
    <PageHeader TitleId="server-title"
                Eyebrow=""
                Title="Local server"
                Subtitle="Expose an OpenAI-compatible endpoint so other apps can use a local model. The app's own chat is unaffected." />

    @* ── 2. STATUS + ACTION merged card ──────────────────────────────────────────────────── *@
    <section class="card server-main"
             aria-labelledby="server-main-title"
             data-testid="server-main">

        @* Status line: pilot-light + plain status text + endpoint when running *@
        <div class="server-status-bar">
            <span class="server-pilot-light @(PilotLightLit ? "is-lit" : string.Empty)"
                  data-testid="server-pilot-light"
                  data-state="@StateName"
                  aria-hidden="true"></span>
            <div class="server-status-text-group">
                <p class="server-status-line"
                   data-testid="server-status"
                   role="status"
                   aria-live="polite">@StatusText</p>
                @if (ServingState.IsRunning && BaseEndpoint is not null)
                {
                    <small class="server-endpoint-caption">OpenAI-compatible endpoint</small>
                }
            </div>
            @if (ServingState.IsRunning && BaseEndpoint is not null && CopyPayload is not null)
            {
                <code class="server-endpoint-code"
                      data-testid="server-endpoint"
                      aria-label="Bound server endpoint"
                      title="@BaseEndpoint">@BaseEndpoint</code>
                <button type="button"
                        class="button button-secondary server-endpoint-copy-btn"
                        data-testid="server-endpoint-copy"
                        aria-label="Copy server endpoint to clipboard"
                        @onclick="CopyEndpointAsync">
                    @_copyButtonText
                </button>
            }
        </div>

        @* Unsupported / error / empty-endpoint notes *@
        @if (!ServingState.IsSupported)
        {
            <p class="server-note server-note--info" data-testid="server-unsupported" role="note">
                The local server is not supported by this build or platform.
            </p>
        }

        @if (!string.IsNullOrWhiteSpace(ServingState.Message))
        {
            <p class="operation-error" data-testid="server-error" role="alert">@ServingState.Message</p>
        }

        @if (ShowEndpointEmpty)
        {
            <p class="server-note server-note--error" data-testid="server-endpoint-empty" role="alert">
                Foundry Local reported a start, but did not return a bound endpoint. No endpoint is shown.
            </p>
        }

        @* Action area: model picker, start/stop, macro stages, success moment *@
        <ServeMacro />

        @* Reachable models (inside the card for Gestalt proximity — only when running) *@
        <ServeModelList />

        @* Quiet limits line *@
        <p class="server-limits-line">Localhost only · No auth · No LAN access</p>

    </section>

    @* ── 3. CONNECT YOUR TOOL (render only when running) ─────────────────────────────────── *@
    @if (ServingState.IsRunning)
    {
        <section class="card server-connect-section" aria-labelledby="server-connect-title">
            <h2 id="server-connect-title" class="server-connect-title">Connect your tool</h2>
            <ServeSnippets />
        </section>
    }

    @* ── 4. REFERENCE — collapsible, collapsed by default ────────────────────────────────── *@
    <details class="card server-reference" data-testid="server-routes">
        <summary class="server-reference__summary">
            <span>Available routes</span>
        </summary>
        <div class="server-reference__body">
            <ul class="server-reference__routes" aria-label="Available API routes">
                @foreach (var route in ServerEndpoints.DocumentedRoutes)
                {
                    <li class="server-reference__route">
                        <code data-testid="server-routes-documented-label">@route.Path</code>
                        <span>@route.Description</span>
                    </li>
                }
            </ul>
            <p class="server-note server-note--info server-reference__honesty" role="note"
               data-testid="server-request-log-omitted">
                Foundry Local exposes no per-request feed, so live activity isn't shown.
            </p>
        </div>
    </details>

</div>

@code {
    private string _copyButtonText = "Copy endpoint";

    private string StateName => ServingState.Status.State.ToString().ToLowerInvariant();
    private bool PilotLightLit => ServerStateMachine.PilotLightLit(ServingState.Status.State);
    private string? BaseEndpoint => ServingState.IsRunning ? ServerEndpoints.BaseUrl(ServingState.Urls) : null;
    private string? CopyPayload => ServingState.IsRunning ? ServerEndpoints.CopyPayload(ServingState.Urls) : null;
    private bool ShowEndpointEmpty => ServingState.EmptyEndpointAfterStart && ServingState.Status.State == ServerState.Error;

    private string StatusText => ServingState.Status.State switch
    {
        ServerState.Starting  => "Starting server…",
        ServerState.Running   => "Running",
        ServerState.Stopping  => "Stopping…",
        ServerState.Error     => "Server error",
        _                     => "Stopped",
    };

    protected override void OnInitialized()
    {
        ServingState.OnChanged += OnServingStateChanged;
    }

    private void OnServingStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task CopyEndpointAsync()
    {
        if (CopyPayload is null) return;

        await Js.InvokeVoidAsync("foundryForgeClipboard.copy", CopyPayload);
        _copyButtonText = "Copied ✓";
        await InvokeAsync(StateHasChanged);
        await Task.Delay(1800);
        _copyButtonText = "Copy endpoint";
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ServingState.OnChanged -= OnServingStateChanged;
    }
}

