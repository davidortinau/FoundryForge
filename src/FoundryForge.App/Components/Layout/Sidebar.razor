@inject NavigationManager Navigation
@inject ServingStateService ServingState
@inject IFoundryCatalogService CatalogService
@inject ISettingsService SettingsService
@implements IDisposable

<aside class="sidebar" aria-label="FoundryForge navigation">
    <a class="sidebar__skip" href="#main-content">Skip to content</a>
    <nav class="sidebar-nav" aria-label="Primary">
        <div class="sidebar-nav__group" aria-labelledby="nav-group-workshop">
            <p id="nav-group-workshop" class="sidebar-nav__eyebrow">Workshop</p>
            <NavLink id="nav-serve" data-testid="nav-serve" class="sidebar-nav__row" href="/server" aria-label="Serve — manage the local server">
                <span class="sidebar-nav__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M5 7h14v4H5z"/><path d="M5 13h14v4H5z"/><path d="M8 9h.01"/><path d="M8 15h.01"/></svg>
                </span>
                <span>Serve</span>
                @if (ServingState.IsRunning)
                {
                    <span class="sidebar-nav__live-dot" aria-label="Server is running" title="Server is running"></span>
                }
            </NavLink>
            <NavLink id="nav-discover" data-testid="nav-discover" class="sidebar-nav__row" href="/" Match="NavLinkMatch.All" aria-label="Discover models">
                <span class="sidebar-nav__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="6"/><path d="m16.5 16.5 3.5 3.5"/></svg>
                </span>
                <span>Discover</span>
            </NavLink>
            <NavLink id="nav-workbench" data-testid="nav-workbench" class="sidebar-nav__row" href="/chat" aria-label="Workbench — chat and compare">
                <span class="sidebar-nav__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M5 6.5h14v9H8l-3 3z"/><path d="M8 10h8"/><path d="M8 13h5"/></svg>
                </span>
                <span>Workbench</span>
            </NavLink>
        </div>
    </nav>

    <div class="sidebar-foot">
        <div class="sidebar-storage" data-testid="sidebar-storage" title="@_cachePath">
            <span class="sidebar-storage__summary">
                <strong>@_cachedCount</strong> local model@(_cachedCount == 1 ? string.Empty : "s")@_cachedSizeSuffix
            </span>
            @if (!string.IsNullOrWhiteSpace(_cachePath))
            {
                <span class="sidebar-storage__path">@_cachePath</span>
            }
        </div>
        <button type="button"
                class="sidebar-settings"
                data-testid="sidebar-settings"
                aria-label="Open settings"
                title="Settings"
                @onclick="OpenSettingsAsync">
            <span class="sidebar-nav__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </span>
            <span>Settings</span>
        </button>
    </div>
</aside>

@code {
    [Parameter] public EventCallback OnOpenSettings { get; set; }

    private int _cachedCount;
    private string _cachedSizeSuffix = string.Empty;
    private string? _cachePath;

    protected override async Task OnInitializedAsync()
    {
        ServingState.OnChanged += OnServingStateChanged;
        Navigation.LocationChanged += OnLocationChanged;
        await RefreshStorageAsync();
    }

    private void OnServingStateChanged() => InvokeAsync(RefreshStorageAsync);

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(RefreshStorageAsync);

    // Ambient local-storage summary for the rail foot. Refreshed on init, on navigation, and on serving-state
    // changes; never blocks and never throws out (best-effort, honest zero on failure).
    private async Task RefreshStorageAsync()
    {
        try
        {
            var cached = await CatalogService.ListCachedAsync();
            _cachedCount = cached.Count;

            var known = cached.Where(m => m.SizeGb is > 0).Select(m => m.SizeGb!.Value).ToList();
            if (known.Count == 0)
            {
                _cachedSizeSuffix = _cachedCount > 0 ? ", size unknown" : string.Empty;
            }
            else
            {
                var total = known.Sum();
                var plus = known.Count < _cachedCount ? "+" : string.Empty;
                _cachedSizeSuffix = $", {total.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)}{plus} GB";
            }
        }
        catch
        {
            _cachedCount = 0;
            _cachedSizeSuffix = string.Empty;
        }

        try
        {
            var settings = await SettingsService.GetAsync();
            _cachePath = settings.ModelCacheDirectory;
        }
        catch
        {
            // Best-effort — leave whatever we had.
        }

        StateHasChanged();
    }

    private Task OpenSettingsAsync() => OnOpenSettings.InvokeAsync();

    public void Dispose()
    {
        ServingState.OnChanged -= OnServingStateChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
